# DevTeam Hub – Environment Variables
# Copy to .env and fill in values

# ── Application ────────────────────────────────────────────────────────────────
SECRET_KEY_BASE=generate_with_rails_secret
APP_VERSION=1.0.0
RAILS_MAX_THREADS=5

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/dev_team_production

# ── Gitea (self-hosted Git server) ─────────────────────────────────────────────
GITEA_URL=http://your-gitea-server:3000
GITEA_TOKEN=your_gitea_api_token
GITEA_WEBHOOK_SECRET=your_webhook_secret_here

# ── Jenkins (CI) ───────────────────────────────────────────────────────────────
JENKINS_URL=http://your-jenkins-server:8080
JENKINS_USER=admin
JENKINS_TOKEN=your_jenkins_api_token
JENKINS_WEBHOOK_SECRET=your_jenkins_webhook_secret

# ── Sentry (APM / Error Tracking) ─────────────────────────────────────────────
SENTRY_DSN=https://your@sentry-dsn.example.com/1
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Jitsi Meet (Video Calls) ──────────────────────────────────────────────────
# Use self-hosted Jitsi or public meet.jit.si
JITSI_URL=https://meet.jit.si

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.your-mail-server.com
SMTP_PORT=587
SMTP_USERNAME=devteam@yourcompany.com
SMTP_PASSWORD=your_smtp_password
MAILER_FROM=devteam@yourcompany.com

# ── Mattermost / Rocket.Chat (Team Chat) ──────────────────────────────────────
CHAT_URL=http://your-mattermost-server:8065
CHAT_WEBHOOK_URL=http://your-mattermost-server:8065/hooks/your-hook-id

# ── AI Agent (local Ollama LLM on the on-prem Mac mini) ────────────────────────
# The Mac mini runs `ollama serve`; point this at its host:port on the LAN.
OLLAMA_URL=http://your-mac-mini.local:11434
# Default model for AI reviews (must be `ollama pull`ed on the Mac mini).
OLLAMA_MODEL=llama3.1
# Max seconds to wait for a completion (local models can be slow on first token).
OLLAMA_TIMEOUT=300

# ── Centralised Logging (Grafana Loki) ─────────────────────────────────────────
# All applications ship logs here; the in-app Log Viewer (/logs) reads from it.
LOKI_URL=http://your-loki-server:3100
