    # ── helpers ────────────────────────────────────────────────────────────────

    def self.has_opt?(args, *names)
      args.any? { |a| names.include?(a.split("=").first) }
    end

    def self.extract_opt(args, *names)
      names.each do |name|
        idx = args.index { |a| a.start_with?(name) }
        next unless idx
        arg = args.delete_at(idx)
        if arg.include?("=")
          return arg.split("=", 2).last
        else
          return args.delete_at(idx)
        end
      end
      nil
    end
  end
end

# ─── Main ──────────────────────────────────────────────────────────────────────

if ARGV.empty? || ARGV.first == "help" || ARGV.first == "--help" || ARGV.first == "-h"
  Dt::Commands.help(ARGV.drop(1))
  exit
end

command = ARGV.shift
args = ARGV.dup

case command
when "setup"            then Dt::Commands.setup(args)
when "ticket", "t"      then Dt::Commands.ticket(args)
when "deploy", "d"      then Dt::Commands.deploy(args)
when "ci"               then Dt::Commands.ci(args)
when "log", "l"         then Dt::Commands.log(args)
when "version", "--version", "-v"
  puts "dt #{Dt::VERSION}"
else
  Dt.error("Unknown command: #{command}")
  puts "  Run #{Dt.paint(:cyan, 'dt help')} for usage."
  exit 1
end
