# See https://help.github.com/articles/ignoring-files for more about ignoring files.

# Ignore bundler config.
/.bundle

# Ignore all environment files.
/.env*
!/.env.example

# Ignore all logfiles and tempfiles.
/log/*
!/log/.keep
/tmp/*
!/tmp/.keep
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore SQLite databases and their write-ahead/shared-memory sidecars.
/db/*.sqlite3
/db/*.sqlite3-*

# Ignore Active Storage uploaded files.
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

# Ignore node modules.
/node_modules

# Ignore precompiled assets / public uploads.
/public/assets

# OS / editor cruft and backups.
.DS_Store
*.bak

# Claude Code personal settings (per-user, not shared).
/.claude/settings.local.json

# Code coverage reports
/coverage
