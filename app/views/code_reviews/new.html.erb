<% content_for :title, "New Code Review" %>

<div class="level mb-4">
  <div class="level-left">
    <div>
      <nav class="breadcrumb is-small"><ul>
        <li><%= link_to "Code Reviews", code_reviews_path %></li>
        <li class="is-active"><a>New</a></li>
      </ul></nav>
      <h1 class="fw-bold mb-1">🔍 New Code Review</h1>
      <p class="text-muted fs-7">Paste a Gitea pull request URL to review its changes, files and test results.</p>
    </div>
  </div>
</div>

<div class="card p-4" style="max-width:720px;">
  <%= form_with url: code_reviews_path, method: :post do %>
    <label class="form-label fw-semibold">Pull request URL</label>
    <input type="url" name="pr_url" required class="form-control mb-2"
           placeholder="http://gitea.local/owner/repo/pulls/42"
           value="<%= params[:pr_url] %>">
    <p class="text-muted fs-7 mb-3">e.g. <code>http://gitea/devteam/print-server/pulls/42</code></p>
    <%= submit_tag "Start review", class: "btn btn-primary" %>
    <%= link_to "Cancel", code_reviews_path, class: "btn btn-link" %>
  <% end %>
</div>
