<% content_for :title, t("admin.users_page.title") %>

<div class="card p-3 mb-3">
  <h1 class="fw-bold fs-4 mb-3">👥 <%= t("admin.users_page.title") %></h1>

  <table class="table table-hover w-100 align-middle mb-0" id="users-table">
    <thead>
      <tr>
        <th><%= t("admin.users_page.col_user") %></th>
        <th><%= t("admin.users_page.col_email") %></th>
        <th><%= t("admin.users_page.col_role") %></th>
        <th><%= t("admin.users_page.col_status") %></th>
        <th class="text-end"><%= t("admin.users_page.col_actions") %></th>
      </tr>
    </thead>
    <tbody>
      <% @users.each do |user| %>
        <tr id="user-row-<%= user.id %>">
          <td>
            <span class="d-inline-flex align-items-center gap-2">
              <%= user_avatar(user, size: 28) %>
              <span><%= user.display_name %></span>
              <% if user == current_user %>
                <span class="badge bg-light text-muted border"><%= t("admin.users_page.you") %></span>
              <% end %>
            </span>
          </td>
          <td class="text-muted"><%= user.email %></td>
          <td><span class="badge bg-light text-dark border"><%= user.role.to_s.humanize %></span></td>
          <td>
            <% if user.blocked? %>
              <span class="badge bg-danger"><%= t("admin.users_page.status_blocked") %></span>
            <% else %>
              <span class="badge bg-success"><%= t("admin.users_page.status_active") %></span>
            <% end %>
          </td>
          <td class="text-end">
            <% if user == current_user %>
              <span class="text-muted fs-7">—</span>
            <% elsif user.blocked? %>
              <%= button_to t("admin.users_page.unblock"), admin_unblock_user_path(user),
                    method: :patch, class: "btn btn-sm btn-outline-success" %>
            <% else %>
              <%= button_to t("admin.users_page.block"), admin_block_user_path(user),
                    method: :patch, class: "btn btn-sm btn-outline-danger",
                    data: { turbo_confirm: t("admin.users_page.block_confirm", name: user.display_name) } %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
