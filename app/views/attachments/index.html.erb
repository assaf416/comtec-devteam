<% content_for :title, t("attachments.title") %>

<div class="d-flex align-items-center justify-content-between mb-4">
  <div>
    <h1 class="fw-bold mb-0">📎 <%= t("attachments.title") %></h1>
    <p class="text-muted small mb-0">
      <%= @project ? @project.name : t("attachments.subtitle") %>
    </p>
  </div>
  <% if @project %>
    <%= link_to "⬆️ #{t('attachments.upload')}", new_project_attachment_path(@project),
          class: "btn btn-primary" %>
  <% end %>
</div>

<%# Content search (title + extracted document text) %>
<div class="card mb-4">
  <div class="card-body py-2">
    <%= form_with url: (@project ? project_attachments_path(@project) : attachments_path),
          method: :get, local: true, class: "d-flex gap-2 align-items-center flex-wrap" do |f| %>
      <div class="flex-grow-1">
        <%= f.search_field :q, value: params[:q],
              class: "form-control form-control-sm",
              placeholder: t("attachments.search_placeholder") %>
      </div>
      <%= f.submit t("attachments.search"), class: "btn btn-sm btn-outline-secondary" %>
      <% if params[:q].present? %>
        <%= link_to t("attachments.clear"),
              (@project ? project_attachments_path(@project) : attachments_path),
              class: "btn btn-sm btn-link text-muted" %>
      <% end %>
    <% end %>
  </div>
</div>

<% if @grouped.empty? %>
  <div class="text-center text-muted py-5">
    <div style="font-size:3rem;">📭</div>
    <p class="mt-2"><%= t("attachments.empty") %></p>
  </div>
<% else %>
  <% @grouped.each do |project, files| %>
    <div class="mb-4">
      <div class="d-flex align-items-center mb-2 gap-2">
        <h5 class="fw-semibold mb-0">
          <%= link_to project.name, project_path(project), class: "text-decoration-none" %>
        </h5>
        <span class="badge bg-secondary"><%= files.size %></span>
        <%= link_to t("attachments.upload"), new_project_attachment_path(project),
              class: "btn btn-sm btn-outline-secondary ms-auto py-0" %>
      </div>

      <div class="row g-2">
        <% files.each do |att| %>
          <div class="col-md-6 col-lg-4">
            <%= link_to attachment_path(att), class: "card h-100 text-decoration-none border-0 shadow-sm" do %>
              <div class="card-body py-2 px-3">
                <div class="d-flex align-items-start gap-2">
                  <span style="font-size:1.4rem;flex-shrink:0;"><%= attachment_type_icon(att) %></span>
                  <div style="min-width:0;flex:1;">
                    <div class="fw-semibold text-truncate small"><%= att.title.presence || att.filename %></div>
                    <div class="text-muted" style="font-size:0.72rem;">
                      <%= attachment_size(att) %>
                      · <%= att.uploaded_by&.display_name || "AI" %>
                      · <%= time_ago_in_words(att.updated_at) %> ago
                    </div>
                    <div class="mt-1"><%= attachment_status_badge(att) %></div>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
<% end %>
