<%= form_with(model: [@customer, installation], class: "card p-3 mb-3") do |f| %>
  <% if installation.errors.any? %>
    <div class="alert alert-danger is-light">
      <ul><% installation.errors.full_messages.each do |m| %><li><%= m %></li><% end %></ul>
    </div>
  <% end %>

  <div class="row">
    <div class="col-5">
      <div class="mb-3">
        <%= f.label :software_name, "Software / Product Name", class: "label" %>
        <div class=""><%= f.text_field :software_name, class: "input", required: true, placeholder: "TDI2 Server, Print Server, Digital Internet..." %></div>
      </div>
    </div>
    <div class="col-3">
      <div class="mb-3">
        <%= f.label :version, class: "label" %>
        <div class=""><%= f.text_field :version, class: "input", required: true, placeholder: "1.2.3" %></div>
      </div>
    </div>
    <div class="col-2">
      <div class="mb-3">
        <%= f.label :environment, class: "label" %>
        <div class="">
          <div class="select w-100">
            <%= f.select :environment, Installation::ENVIRONMENTS.map { |e| [e.capitalize, e] }, {}, { required: true } %>
          </div>
        </div>
      </div>
    </div>
    <div class="col-2">
      <div class="mb-3">
        <%= f.label :status, class: "label" %>
        <div class="">
          <div class="select w-100">
            <%= f.select :status, Installation.statuses.keys.map { |s| [s.humanize, s] } %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="row">
    <div class="col">
      <div class="mb-3">
        <%= f.label :project_id, "Related Project (optional)", class: "label" %>
        <div class="">
          <div class="select w-100">
            <%= f.select :project_id, Project.active.order(:name).map { |p| [p.name, p.id] }, { include_blank: "— None —" } %>
          </div>
        </div>
      </div>
    </div>
    <div class="col">
      <div class="mb-3">
        <%= f.label :deployment_id, "From Deployment (optional)", class: "label" %>
        <div class="">
          <div class="select w-100">
            <%= f.select :deployment_id,
                Deployment.order(created_at: :desc).limit(50).map { |d| ["##{d.id} #{d.project.name} v#{d.version_tag}", d.id] rescue ["##{d.id}", d.id] },
                { include_blank: "— None —" } %>
          </div>
        </div>
      </div>
    </div>
    <div class="col">
      <div class="mb-3">
        <%= f.label :installed_at, "Installation Date/Time", class: "label" %>
        <div class=""><%= f.datetime_local_field :installed_at, class: "input" %></div>
      </div>
    </div>
  </div>

  <div class="mb-3">
    <%= f.label :notes, class: "label" %>
    <div class=""><%= f.text_area :notes, class: "textarea", rows: 3, placeholder: "Configuration notes, license keys, special setup..." %></div>
  </div>

  <div class="d-flex gap-2 align-items-end">
    <div class=""><%= f.submit installation.new_record? ? "Track Installation" : "Update Installation", class: "btn btn-primary" %></div>
    <div class=""><%= link_to "Cancel", customer_installations_path(@customer), class: "btn btn-secondary" %></div>
  </div>
<% end %>
