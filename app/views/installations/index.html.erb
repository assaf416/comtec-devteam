<div class="level">
  <div class="level-left">
    <div>
      <nav class="breadcrumb is-small"><ul><li><%= link_to "Customers", customers_path %></li><li><%= link_to @customer.name, @customer %></li><li class="is-active"><a>Installations</a></li></ul></nav>
      <h1 class="fw-bold">Installations — <%= @customer.name %></h1>
    </div>
  </div>
  <div class="level-right">
    <%= link_to t("buttons.track_new_installation"), new_customer_installation_path(@customer), class: "btn btn-primary" %>
  </div>
</div>

<div class="row align-items-center mb-4">
  <% Installation::ENVIRONMENTS.each do |env| %>
    <div class="col-auto">
      <%= link_to env.capitalize, customer_installations_path(@customer, environment: env),
          class: "btn btn-secondary btn-sm #{ params[:environment] == env ? 'is-info' : 'is-light' }" %>
    </div>
  <% end %>
  <div class="col-auto">
    <%= link_to "All", customer_installations_path(@customer), class: "btn btn-secondary btn-sm #{ params[:environment].blank? ? 'is-info' : 'is-light' }" %>
  </div>
</div>

<% if @installations.any? %>
  <table class="table table-striped table-hover w-100">
    <thead>
      <tr><th><%= t('table_headers.software') %></th><th><%= t('table_headers.version') %></th><th><%= t('table_headers.environment') %></th><th><%= t('table_headers.project') %></th><th><%= t('table_headers.installed') %></th><th><%= t('table_headers.status') %></th><th></th></tr>
    </thead>
    <tbody>
      <% @installations.each do |inst| %>
        <tr class="<%= 'bg-warning-subtle' if inst.status_outdated? %><%= ' bg-danger-subtle' if inst.status_failed? %>">
          <td><strong><%= link_to inst.software_name, customer_installation_path(@customer, inst) %></strong></td>
          <td><code><%= inst.version %></code></td>
          <td><span class="badge bg-light text-dark"><%= inst.environment %></span></td>
          <td><%= inst.project&.name || "—" %></td>
          <td><%= inst.installed_at&.strftime("%d/%m/%Y") || "—" %></td>
          <td><%= status_tag(inst.status) %></td>
          <td>
            <%= actions_dropdown do |d| %>
              <% d.link t('common.actions.edit'), edit_customer_installation_path(@customer, inst), icon: '✏️' %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <div class="alert alert-light">No installations tracked yet.</div>
<% end %>
