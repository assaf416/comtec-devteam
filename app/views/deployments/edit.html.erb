<div class="d-flex align-items-center mb-4 gap-2">
  <%= link_to deployment_path(@deployment), class: "btn btn-sm btn-outline-secondary" do %>
    <i class="bi bi-arrow-left"></i> Back
  <% end %>
  <h2 class="mb-0">Edit Deployment — <%= @project.name %> v<%= @deployment.version %></h2>
</div>

<div class="card shadow-sm">
  <div class="card-body">
    <%= render "form", deployment: @deployment %>
  </div>
</div>
