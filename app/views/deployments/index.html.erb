<%
  status_colors = { "succeeded" => "success", "failed" => "danger", "in_progress" => "primary",
                    "pending" => "secondary", "rolled_back" => "warning" }
%>

<div class="d-flex align-items-center justify-content-between mb-4">
  <h2 class="mb-0"><i class="bi bi-rocket-takeoff me-2"></i>Deployments — <%= @project.name %></h2>
  <%= link_to new_project_deployment_path(@project), class: "btn btn-primary btn-sm" do %>
    <i class="bi bi-plus-lg me-1"></i>New Deployment
  <% end %>
</div>

<%# Filters %>
<div class="d-flex gap-2 mb-3 flex-wrap">
  <%= link_to "All", project_deployments_path(@project),
        class: "btn btn-sm #{params[:environment].blank? && params[:status].blank? ? 'btn-dark' : 'btn-outline-secondary'}" %>
  <% %w[production staging qa].each do |env| %>
    <%= link_to env.capitalize, project_deployments_path(@project, environment: env),
          class: "btn btn-sm #{params[:environment] == env ? 'btn-dark' : 'btn-outline-secondary'}" %>
  <% end %>
  <span class="text-muted my-auto mx-1">|</span>
  <% Deployment.statuses.keys.each do |s| %>
    <%= link_to s.humanize, project_deployments_path(@project, status: s),
          class: "btn btn-sm #{params[:status] == s ? 'btn-dark' : 'btn-outline-secondary'}" %>
  <% end %>
</div>

<% if @deployments.any? %>
  <div class="card shadow-sm">
    <div class="card-body p-0">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th class="ps-3">Version</th>
            <th>Environment</th>
            <th>Type</th>
            <th>Status</th>
            <th>Env Vars</th>
            <th>Deployed By</th>
            <th>Deployed At</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @deployments.each do |dep| %>
            <% badge = status_colors.fetch(dep.status, "secondary") %>
            <% env_count = Array(dep.env_vars).count { |r| r["key"].present? } %>
            <tr>
              <td class="ps-3"><code class="fw-semibold"><%= dep.version %></code></td>
              <td><span class="badge bg-secondary"><%= dep.environment.capitalize %></span></td>
              <td><%= dep.deploy_type&.humanize %></td>
              <td><span class="badge bg-<%= badge %>"><%= dep.status.humanize %></span></td>
              <td>
                <% if env_count > 0 %>
                  <span class="badge bg-info text-dark"><i class="bi bi-sliders me-1"></i><%= env_count %></span>
                <% else %>
                  <span class="text-muted">—</span>
                <% end %>
              </td>
              <td><%= dep.deployed_by&.name || "—" %></td>
              <td><%= dep.deployed_at&.strftime("%b %-d, %Y") || "—" %></td>
              <td class="pe-3 text-end">
                <%= link_to dep, class: "btn btn-sm btn-outline-secondary me-1" do %><i class="bi bi-eye"></i><% end %>
                <%= link_to edit_deployment_path(dep), class: "btn btn-sm btn-outline-secondary" do %><i class="bi bi-pencil"></i><% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% else %>
  <div class="text-center py-5 text-muted">
    <i class="bi bi-rocket-takeoff display-4 d-block mb-3"></i>
    No deployments recorded yet.
    <%= link_to "Create the first one", new_project_deployment_path(@project) %>
  </div>
<% end %>
