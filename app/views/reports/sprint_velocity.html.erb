<% content_for :title, "Sprint Velocity" %>

<div class="level mb-4">
  <div class="level-left">
    <h1 class="fw-bold mb-0">Sprint Velocity</h1>
  </div>
</div>

<div class="row mb-4">
  <div class="col-4"><div class="card p-3 mb-3 stat-card"><div class="stat-number"><%= @total_sprints %></div><div class="stat-label">Total Sprints</div></div></div>
  <div class="col-4"><div class="card p-3 mb-3 stat-card"><div class="stat-number text-success"><%= @completed_sprints %></div><div class="stat-label">Completed</div></div></div>
  <div class="col-4"><div class="card p-3 mb-3 stat-card"><div class="stat-number text-info"><%= @active_sprints %></div><div class="stat-label">Active</div></div></div>
</div>

<div class="row">
  <div class="col-8">
    <div class="card p-3 mb-3">
      <h3 class="subfw-bold">Velocity by Sprint</h3>
      <%= line_chart @velocity_by_sprint, height: "300px" %>
    </div>
  </div>
  <div class="col-4">
    <div class="card p-3 mb-3">
      <h3 class="subfw-bold">Average Velocity by Project</h3>
      <%= pie_chart @project_average_velocity, height: "300px" %>
    </div>
  </div>
</div>

<div class="card p-3 mb-3">
  <h3 class="subfw-bold">Sprint Completion Rate</h3>
  <%= bar_chart @sprint_completion, suffix: "%", min: 0, max: 100, height: "320px" %>
</div>

<div class="card p-3">
  <h3 class="subfw-bold">Recent Sprints</h3>
  <table class="table table-hover w-100 fs-7">
    <thead>
      <tr>
        <th><%= t('table_headers.sprint') %></th>
        <th><%= t('table_headers.project') %></th>
        <th><%= t('table_headers.status') %></th>
        <th><%= t('table_headers.start') %></th>
        <th><%= t('table_headers.end') %></th>
        <th><%= t('table_headers.velocity') %></th>
        <th><%= t('table_headers.tickets') %></th>
      </tr>
    </thead>
    <tbody>
      <% @recent_sprints.each do |sprint| %>
        <tr>
          <td><%= sprint.name %></td>
          <td><%= sprint.project.name %></td>
          <td><%= status_tag(sprint.status) %></td>
          <td><%= sprint.start_date&.strftime("%Y-%m-%d") %></td>
          <td><%= sprint.end_date&.strftime("%Y-%m-%d") %></td>
          <td><%= sprint.velocity || "-" %></td>
          <td><%= sprint.tickets.count %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
