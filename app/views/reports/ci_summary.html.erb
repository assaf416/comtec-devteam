<% content_for :title, "CI Summary" %>

<div class="level mb-4">
  <div class="level-left">
    <h1 class="fw-bold mb-0">CI Summary</h1>
  </div>
</div>

<div class="row mb-4">
  <div class="col-3"><div class="card p-3 mb-3 stat-card"><div class="stat-number"><%= @total_runs %></div><div class="stat-label">Total Runs</div></div></div>
  <div class="col-3"><div class="card p-3 mb-3 stat-card"><div class="stat-number text-success"><%= @passed_runs %></div><div class="stat-label">Passed</div></div></div>
  <div class="col-3"><div class="card p-3 mb-3 stat-card"><div class="stat-number text-danger"><%= @failed_runs %></div><div class="stat-label">Failed</div></div></div>
  <div class="col-3"><div class="card p-3 mb-3 stat-card"><div class="stat-number text-warning"><%= @running_runs %></div><div class="stat-label">Running</div></div></div>
</div>

<div class="row">
  <div class="col-8">
    <div class="card p-3 mb-3">
      <h3 class="subfw-bold">Runs Trend (Last 30 Days)</h3>
      <%= line_chart @runs_by_day, height: "280px", library: { plugins: { legend: { display: false } } } %>
    </div>
  </div>
  <div class="col-4">
    <div class="card p-3 mb-3">
      <h3 class="subfw-bold">Status Breakdown</h3>
      <%= pie_chart @status_breakdown, height: "280px" %>
    </div>
  </div>
</div>

<div class="card p-3 mb-3">
  <h3 class="subfw-bold">Project Pass Rate</h3>
  <%= column_chart @project_pass_rate, suffix: "%", max: 100, height: "300px" %>
</div>

<div class="card p-3">
  <h3 class="subfw-bold">Latest CI Runs</h3>
  <table class="table table-hover w-100 fs-7">
    <thead>
      <tr>
        <th><%= t('table_headers.build') %></th>
        <th><%= t('table_headers.project') %></th>
        <th><%= t('table_headers.branch') %></th>
        <th><%= t('table_headers.status') %></th>
        <th><%= t('table_headers.started') %></th>
        <th><%= t('table_headers.duration') %></th>
      </tr>
    </thead>
    <tbody>
      <% @latest_runs.each do |run| %>
        <tr>
          <td>#<%= run.build_number %></td>
          <td><%= run.project.name %></td>
          <td><code><%= run.branch_name.presence || "-" %></code></td>
          <td><%= status_tag(run.status) %></td>
          <td><%= run.started_at ? l(run.started_at, format: :short) : "-" %></td>
          <td><%= run.duration ? "#{run.duration}m" : "-" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
