<%= form_with(model: customer, class: "card p-3 mb-3") do |f| %>
  <% if customer.errors.any? %>
    <div class="alert alert-danger is-light">
      <ul><% customer.errors.full_messages.each do |m| %><li><%= m %></li><% end %></ul>
    </div>
  <% end %>

  <div class="row">
    <div class="col">
      <div class="mb-3">
        <%= f.label :name, class: "label" %>
        <div class=""><%= f.text_field :name, class: "input", required: true %></div>
      </div>
    </div>
    <div class="col">
      <div class="mb-3">
        <%= f.label :company, class: "label" %>
        <div class=""><%= f.text_field :company, class: "input" %></div>
      </div>
    </div>
  </div>

  <div class="row">
    <div class="col">
      <div class="mb-3">
        <%= f.label :email, class: "label" %>
        <div class=""><%= f.email_field :email, class: "input", required: true %></div>
      </div>
    </div>
    <div class="col">
      <div class="mb-3">
        <%= f.label :phone, class: "label" %>
        <div class=""><%= f.telephone_field :phone, class: "input" %></div>
      </div>
    </div>
    <div class="col">
      <div class="mb-3">
        <%= f.label :contact_person, "Primary Contact", class: "label" %>
        <div class=""><%= f.text_field :contact_person, class: "input" %></div>
      </div>
    </div>
  </div>

  <div class="mb-3">
    <%= f.label :notes, class: "label" %>
    <div class=""><%= f.text_area :notes, class: "textarea", rows: 3 %></div>
  </div>

  <div class="mb-3">
    <div class="">
      <%= f.check_box :active %>
      <%= f.label :active, "Active customer", class: "ms-2" %>
    </div>
  </div>

  <div class="d-flex gap-2 align-items-end">
    <div class="">
      <%= f.submit customer.new_record? ? "Add Customer" : "Update Customer", class: "btn btn-primary" %>
    </div>
    <div class="">
      <%= link_to "Cancel", customer.new_record? ? customers_path : customer_path(customer), class: "btn btn-secondary" %>
    </div>
  </div>
<% end %>
