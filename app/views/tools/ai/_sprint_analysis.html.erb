<%# Rendered into the lazy Turbo Frame embedded on the sprint page. %>
<turbo-frame id="ai_sprint_analysis">
  <div class="card p-3 mb-4" style="border-left:4px solid #7048e8;">
    <div class="d-flex align-items-center mb-2">
      <strong>🤖 <%= t("ai.sprint_analysis_title") %></strong>
      <% if review.verdict.present? %>
        <span class="badge <%= review.verdict_badge_class %> ms-2"><%= review.verdict.humanize %></span>
      <% end %>
      <% if review.score.present? %>
        <span class="badge bg-secondary ms-1"><%= t("ai.col.score") %>: <%= review.score %></span>
      <% end %>
      <span class="ms-auto text-muted fs-7">
        <%= review.llm_model %><% if review.duration_seconds %> · <%= review.duration_seconds %>s<% end %>
      </span>
    </div>

    <% if review.status_failed? %>
      <div class="alert alert-warning is-light mb-2 fs-7">
        <%= t("ai.offline_hint") %><br>
        <span class="text-muted"><%= review.error_message %></span>
      </div>
    <% elsif review.body.present? %>
      <div class="content markdown-body fs-7"><%= render_markdown(review.body) %></div>
    <% else %>
      <p class="text-muted fs-7"><%= t("ai.no_output") %></p>
    <% end %>

    <div class="d-flex gap-2 align-items-center mt-2">
      <%= button_to t("ai.refresh"), tools_ai_sprint_analysis_path(sprint_id: sprint.id),
            method: :post, class: "btn btn-sm btn-secondary",
            form: { data: { turbo_frame: "ai_sprint_analysis" } } %>
      <%= link_to t("ai.open_full"), tools_ai_review_path(review), class: "btn btn-sm btn-link",
            data: { turbo_frame: "_top" } %>
    </div>
  </div>
</turbo-frame>
