<%# Sprint selector for the ceremony pages. locals: sprints, selected, url %>
<%= form_with url: url, method: :get, class: "d-flex align-items-center gap-2" do %>
  <label class="fs-7 text-muted mb-0">Sprint</label>
  <select name="sprint_id" class="form-select form-select-sm" style="max-width:340px;"
          onchange="this.form.requestSubmit()">
    <% sprints.each do |s| %>
      <option value="<%= s.id %>" <%= "selected" if selected && s.id == selected.id %>>
        <%= s.project.name %> · <%= s.name %><%= " (active)" if s.active? %>
      </option>
    <% end %>
  </select>
<% end %>
