<% content_for :title, "Edit test — #{File.basename(@path.presence || 'feature')}" %>

<style>
  .gherkin-wrap { position: relative; border-radius: 10px; overflow: hidden; border: 1px solid #1c2330;
    font-family: 'JetBrains Mono', ui-monospace, Menlo, monospace; font-size: .86rem; line-height: 1.55; }
  .gherkin-wrap pre, .gherkin-wrap textarea {
    margin: 0; padding: 14px 16px; white-space: pre-wrap; word-break: break-word;
    font: inherit; tab-size: 2; border: 0;
  }
  .gherkin-hl { background: #0e1116; color: #aab2bd; min-height: 52vh; }
  .gherkin-wrap textarea {
    position: absolute; inset: 0; height: 100%; width: 100%; background: transparent;
    color: transparent; caret-color: #e8e6df; resize: none; outline: none; overflow: hidden;
  }
  .gh-feature  { color: #7aa2f7; font-weight: 700; }
  .gh-scenario { color: #9ece6a; font-weight: 700; }
  .gh-step     { color: #e0af68; font-weight: 600; }
  .gh-tag      { color: #bb9af7; }
  .gh-string   { color: #9ece6a; }
  .gh-param    { color: #f7768e; }
  .gh-comment  { color: #5c6370; font-style: italic; }
</style>

<div class="level mb-3">
  <div class="level-left">
    <div>
      <nav class="breadcrumb is-small"><ul>
        <% if @ticket %><li><%= link_to "T-#{@ticket.id}", ticket_path(@ticket) %></li><% end %>
        <li class="is-active"><a>🧪 Edit test</a></li>
      </ul></nav>
      <h1 class="fw-bold mb-1">🧪 Cucumber Test Editor</h1>
      <p class="text-muted fs-7 mb-0"><code><%= @path.presence || "feature" %></code><% if @ticket %> · <%= @ticket.title.truncate(60) %><% end %></p>
    </div>
  </div>
  <div class="level-right">
    <% if @pull_request %>
      <%= link_to "← Back to PR ##{@pull_request.pr_number}", pull_request_path(@pull_request), class: "btn btn-secondary btn-sm" %>
    <% elsif @ticket %>
      <%= link_to "← Back to ticket", ticket_path(@ticket), class: "btn btn-secondary btn-sm" %>
    <% end %>
  </div>
</div>

<% if @deploy&.ok? %>
  <div class="alert alert-success">
    ✅ Pull request opened:
    <%= link_to @deploy.pr_url, @deploy.pr_url, target: "_blank", rel: "noopener noreferrer" %>
    <span class="text-muted">(branch <code><%= @deploy.branch %></code>)</span>
  </div>
<% end %>

<%= form_with url: review_cucumber_test_path, method: :post do %>
  <%= hidden_field_tag :ticket_id, @ticket&.id %>
  <%= hidden_field_tag :pull_request_id, @pull_request&.id %>
  <%= hidden_field_tag :project_id, @project&.id %>

  <div class="row g-2 mb-2">
    <div class="col-md-8">
      <%= text_field_tag :path, @path, class: "form-control form-control-sm",
            placeholder: "features/example.feature" %>
    </div>
    <div class="col-md-4">
      <%= text_field_tag :message, nil, class: "form-control form-control-sm",
            placeholder: "Commit message (optional)" %>
    </div>
  </div>

  <div class="gherkin-wrap mb-2" data-controller="gherkin-editor">
    <pre class="gherkin-hl" data-gherkin-editor-target="highlight" aria-hidden="true"></pre>
    <textarea name="content" spellcheck="false" autocapitalize="off" autocomplete="off"
              data-gherkin-editor-target="input"
              data-action="input->gherkin-editor#render scroll->gherkin-editor#sync"><%= @content %></textarea>
  </div>

  <div class="d-flex gap-2 align-items-center flex-wrap">
    <%= submit_tag "🧪 Review with AI", class: "btn btn-primary" %>
    <%= submit_tag "🚀 Deploy to GitHub", class: "btn btn-success",
          formaction: deploy_cucumber_test_path %>
    <span class="text-muted fs-7">Review the edited Gherkin with the local LLM, or deploy it to GitHub as a new branch &amp; pull request.</span>
  </div>
<% end %>

<% if @review %>
  <div class="card p-3 mt-4">
    <div class="d-flex align-items-center mb-2">
      <h2 class="fs-6 fw-bold mb-0">🤖 AI test review</h2>
      <% if @review.verdict.present? %><span class="badge <%= @review.verdict_badge_class %> ms-2"><%= @review.verdict.humanize %></span><% end %>
      <%= link_to "Full report", tools_ai_review_path(@review), class: "ms-auto fs-7" %>
    </div>
    <% if @review.status_failed? %>
      <div class="alert alert-warning is-light fs-7 mb-0"><%= @review.error_message %></div>
    <% else %>
      <div class="content markdown-body fs-7"><%= render_markdown(@review.body) %></div>
    <% end %>
  </div>
<% end %>
