<%
  status_colors = { "open" => "success", "review" => "primary", "merged" => "purple", "closed" => "secondary" }
  badge_class   = "bg-#{status_colors.fetch(@pull_request.status, 'secondary')}"
%>

<style>
  .pr-file-item:hover { background: #f3f4f6; }
  .pr-file-item.active-file { background: #e6efff; }
  /* Bootstrap grid columns are flex items with min-width:auto, so a wide,
     non-wrapping code <pre> stretches the column and breaks the layout.
     min-width:0 lets the column shrink and the code viewer scroll instead. */
  .pr-layout > [class*="col-"],
  .pr-files-grid > [class*="col-"] { min-width: 0; }
</style>

<div class="d-flex align-items-start justify-content-between mb-3">
  <div>
    <%= link_to project_pull_requests_path(@project), class: "text-muted small text-decoration-none" do %>
      <i class="bi bi-arrow-left me-1"></i>All PRs — <%= @project.name %>
    <% end %>
    <h2 class="fw-bold mb-1 mt-1">
      <span class="text-muted me-2">#<%= @pull_request.pr_number %></span>
      <%= @pull_request.title %>
    </h2>
    <div class="d-flex gap-2 align-items-center flex-wrap">
      <span class="badge <%= badge_class %>"><%= @pull_request.status.capitalize %></span>
      <% if @pull_request.author.present? %>
        <span class="badge bg-light text-dark border">
          <i class="bi bi-person me-1"></i><%= @pull_request.author %>
        </span>
      <% end %>
      <% if @pull_request.ticket %>
        <span class="badge bg-light text-dark border">
          <i class="bi bi-ticket me-1"></i>
          <%= link_to @pull_request.ticket.title.truncate(40), ticket_path(@pull_request.ticket), class: "text-dark text-decoration-none" %>
        </span>
      <% end %>
      <% if @pull_request.gitea_url.present? %>
        <%= link_to @pull_request.gitea_url, target: "_blank", class: "badge bg-light text-dark border text-decoration-none" do %>
          <i class="bi bi-box-arrow-up-right me-1"></i>View on Gitea
        <% end %>
      <% end %>
    </div>
  </div>

  <div class="d-flex flex-column align-items-end gap-1">
    <div class="d-flex gap-2">
      <% unless @pull_request.status == "merged" %>
        <%= link_to cockpit_pull_request_path(@pull_request), class: "btn btn-success" do %>
          <i class="bi bi-git me-1"></i>Merge cockpit
        <% end %>
      <% end %>
      <%= button_to sync_pull_request_path(@pull_request), method: :post,
            class: "btn btn-primary",
            data: { confirm: "Refresh data from Gitea?" } do %>
        <i class="bi bi-arrow-clockwise me-1"></i>Refresh from Gitea
      <% end %>
    </div>
    <% if @pull_request.synced? %>
      <small class="text-muted">
        <i class="bi bi-check-circle me-1"></i>Last synced <%= @pull_request.synced_at.strftime("%b %-d, %Y %H:%M") %>
      </small>
    <% else %>
      <small class="text-warning"><i class="bi bi-exclamation-circle me-1"></i>Never synced</small>
    <% end %>
  </div>
</div>

<% if @pull_request.description.present? %>
  <div class="card mb-3 shadow-sm">
    <div class="card-body"><%= @pull_request.description %></div>
  </div>
<% end %>

<div class="row g-3 pr-layout">

  <%# ── Left column ───────────────────────────────────────────── %>
  <div class="col-lg-8">

    <%# Files — navigator + code viewer (edit .feature files in the test editor) %>
    <% files = @pull_request.pr_files %>
    <div class="card shadow-sm mb-3" data-controller="pr-files">
      <div class="card-header d-flex align-items-center justify-content-between">
        <strong><i class="bi bi-file-earmark-code me-2"></i>Files</strong>
        <span class="badge bg-secondary"><%= files.size %></span>
      </div>
      <% if files.any? %>
        <div class="row g-0 pr-files-grid">
          <%# file list %>
          <div class="col-md-4 border-end" style="max-height:540px;overflow:auto;">
            <% files.each_with_index do |f, i| %>
              <% feature = f["path"].to_s.end_with?(".feature") %>
              <button type="button"
                      class="btn text-start w-100 border-0 rounded-0 px-3 py-2 pr-file-item <%= 'active-file' if i.zero? %>"
                      data-pr-files-target="item" data-index="<%= i %>" data-action="pr-files#select">
                <div class="font-monospace small text-truncate"><%= feature ? "🧪" : "📄" %> <%= f["path"] %></div>
                <div class="fs-8">
                  <span class="text-success">+<%= f["additions"] || 0 %></span>
                  <span class="text-danger">-<%= f["deletions"] || 0 %></span>
                  <span class="badge bg-light text-dark border ms-1"><%= f["language"] %></span>
                </div>
              </button>
            <% end %>
          </div>
          <%# code viewer %>
          <div class="col-md-8">
            <% files.each_with_index do |f, i| %>
              <div data-pr-files-target="panel" data-index="<%= i %>" class="<%= 'd-none' unless i.zero? %>">
                <div class="d-flex align-items-center gap-2 px-3 py-2 border-bottom bg-light">
                  <code class="small flex-grow-1 text-truncate"><%= f["path"] %></code>
                  <% if f["path"].to_s.end_with?(".feature") %>
                    <%= link_to "🧪 Edit test", edit_cucumber_test_path(pull_request_id: @pull_request.id, path: f["path"]),
                          class: "btn btn-sm btn-outline-primary" %>
                  <% elsif f["url"].present? %>
                    <%= link_to "View on Gitea ↗", f["url"], target: "_blank", rel: "noopener", class: "btn btn-sm btn-outline-secondary" %>
                  <% end %>
                </div>
                <pre class="mb-0 p-3 overflow-auto" style="max-height:480px;background:#0d1117;color:#e6edf3;font-size:.82rem;"><%= f["content"].presence || "(no preview — view on Gitea)" %></pre>
              </div>
            <% end %>
          </div>
        </div>
      <% else %>
        <div class="card-body text-muted small"><i class="bi bi-info-circle me-1"></i>No file data — click Refresh from Gitea.</div>
      <% end %>
    </div>

  </div>

  <%# ── Right column ──────────────────────────────────────────── %>
  <div class="col-lg-4">

    <%# Tests in this PR (with results + coverage) %>
    <% prtests = @pull_request.pr_tests %>
    <% if prtests.any? %>
      <div class="card shadow-sm mb-3">
        <div class="card-header d-flex align-items-center justify-content-between">
          <strong><i class="bi bi-check2-all me-2"></i>Tests (<%= prtests.size %>)</strong>
          <% if @pull_request.coverage_percent.present? %>
            <span class="badge bg-info text-dark">Coverage <%= @pull_request.coverage_percent %>%</span>
          <% end %>
        </div>
        <table class="table table-sm mb-0 small align-middle">
          <tbody>
            <% prtests.each do |t| %>
              <% st = t["status"].to_s %>
              <% badge = st == "passed" ? "bg-success" : (st == "failed" ? "bg-danger" : "bg-secondary") %>
              <tr>
                <td style="width:1%;"><span class="badge <%= badge %>"><%= st == "passed" ? "✓" : (st == "failed" ? "✗" : "⤳") %></span></td>
                <td>
                  <div class="fw-semibold"><%= t["name"] %></div>
                  <div class="text-muted"><code class="fs-8"><%= t["file"] %></code></div>
                </td>
                <td><span class="badge bg-light text-dark border"><%= t["suite"] %></span></td>
                <td class="text-end text-muted text-nowrap"><%= t["time_ms"] %>ms</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>

    <%# CI / Test Results summary %>
    <div class="card shadow-sm mb-3">
      <div class="card-header">
        <strong><i class="bi bi-cpu me-2"></i>CI Results</strong>
      </div>
      <% results = @pull_request.latest_test_results %>
      <% if results.is_a?(Hash) && results["total"].present? %>
        <div class="card-body">
          <div class="d-flex gap-3 align-items-center">
            <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i><%= results["passed"] %> passed</span>
            <% if results["failed"].to_i > 0 %>
              <span class="badge bg-danger"><i class="bi bi-x-circle me-1"></i><%= results["failed"] %> failed</span>
            <% end %>
            <% if results["skipped"].to_i > 0 %>
              <span class="badge bg-secondary"><i class="bi bi-skip-forward me-1"></i><%= results["skipped"] %> skipped</span>
            <% end %>
            <span class="text-muted small"><%= results["total"] %> total</span>
          </div>
        </div>
      <% elsif results.is_a?(Array) && results.any? %>
        <ul class="list-group list-group-flush">
          <% results.each do |s| %>
            <%
              state = s["state"].to_s
              icon  = state == "success" ? "check-circle-fill text-success" : (state == "failure" ? "x-circle-fill text-danger" : "clock-fill text-warning")
            %>
            <li class="list-group-item py-2 small">
              <i class="bi bi-<%= icon %> me-2"></i>
              <span class="fw-semibold"><%= s["context"] %></span>
              <% if s["description"].present? %>
                <div class="text-muted ms-4"><%= s["description"] %></div>
              <% end %>
              <% if s["target_url"].present? %>
                <div class="ms-4"><%= link_to "View details", s["target_url"], target: "_blank", class: "small" %></div>
              <% end %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="card-body text-muted small">No CI data — sync to refresh.</div>
      <% end %>
    </div>

    <%# Build Errors %>
    <% if @pull_request.build_errors.present? %>
      <div class="card shadow-sm mb-3 border-danger">
        <div class="card-header bg-danger text-white">
          <strong><i class="bi bi-exclamation-triangle me-2"></i>Build Errors</strong>
        </div>
        <div class="card-body p-0">
          <pre class="mb-0 p-3 overflow-auto small text-danger" style="max-height:240px;"><%= @pull_request.build_errors %></pre>
        </div>
      </div>
    <% end %>

    <%# PR Comments from Gitea %>
    <div class="card shadow-sm mb-3">
      <div class="card-header d-flex justify-content-between">
        <strong><i class="bi bi-chat-dots me-2"></i>PR Comments</strong>
        <span class="badge bg-secondary"><%= @pull_request.pr_comments.size %></span>
      </div>
      <% if @pull_request.pr_comments.any? %>
        <ul class="list-group list-group-flush">
          <% @pull_request.pr_comments.each do |c| %>
            <li class="list-group-item small py-2">
              <div class="fw-semibold mb-1">
                <i class="bi bi-person me-1"></i><%= c["user"].presence || "unknown" %>
                <% if c["created_at"].present? %>
                  <span class="text-muted fw-normal ms-2"><%= Time.parse(c["created_at"]).strftime("%b %-d, %H:%M") rescue c["created_at"] %></span>
                <% end %>
              </div>
              <div><%= c["message"] %></div>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="card-body text-muted small">No comments — sync to load.</div>
      <% end %>
    </div>

    <%# App-level comments (from Comment model) %>
    <% if @pull_request.comments.any? %>
      <div class="card shadow-sm mb-3">
        <div class="card-header">
          <strong><i class="bi bi-chat-left-text me-2"></i>Team Comments</strong>
        </div>
        <ul class="list-group list-group-flush">
          <% @pull_request.comments.includes(:author).order(:created_at).each do |c| %>
            <li class="list-group-item small py-2">
              <div class="fw-semibold"><%= c.author&.display_name.presence || "Anon" %> <span class="text-muted fw-normal"><%= c.created_at.strftime("%b %-d") %></span></div>
              <div><%= c.body %></div>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%# Metadata %>
    <div class="card shadow-sm">
      <div class="card-header"><strong><i class="bi bi-info-circle me-2"></i>Details</strong></div>
      <ul class="list-group list-group-flush small">
        <li class="list-group-item d-flex justify-content-between">
          <span class="text-muted">Created</span>
          <span><%= @pull_request.created_at.strftime("%b %-d, %Y") %></span>
        </li>
        <li class="list-group-item d-flex justify-content-between">
          <span class="text-muted">Updated</span>
          <span><%= @pull_request.updated_at.strftime("%b %-d, %Y %H:%M") %></span>
        </li>
        <% if @pull_request.merged_at %>
          <li class="list-group-item d-flex justify-content-between">
            <span class="text-muted">Merged</span>
            <span><%= @pull_request.merged_at.strftime("%b %-d, %Y") %></span>
          </li>
        <% end %>
      </ul>
    </div>

  </div>
</div>
