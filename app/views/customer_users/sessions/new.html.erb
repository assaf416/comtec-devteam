<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Customer Portal Login — DevTeam Hub</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>
  <body class="bg-primary min-vh-100 d-flex align-items-center justify-content-center">
    <div class="card shadow" style="width:100%;max-width:420px;">
      <div class="card-body p-4 p-md-5">
        <div class="text-center mb-4">
          <div style="font-size:2.5rem;">🏢</div>
          <h1 class="fw-bold fs-4 mt-2">Customer Portal</h1>
          <p class="text-muted small">DevTeam Hub</p>
        </div>

        <% flash.each do |type, msg| %>
          <% css = type == 'alert' ? 'danger' : 'info' %>
          <div class="alert alert-<%= css %> alert-dismissible fade show" role="alert">
            <%= msg %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
          </div>
        <% end %>

        <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
          <div class="mb-3">
            <%= f.label :email, class: "form-label fw-semibold" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email",
                  class: "form-control", placeholder: "your@email.com" %>
          </div>

          <div class="mb-3">
            <%= f.label :password, class: "form-label fw-semibold" %>
            <%= f.password_field :password, autocomplete: "current-password",
                  class: "form-control", placeholder: "••••••••" %>
          </div>

          <% if devise_mapping.rememberable? %>
            <div class="mb-3 form-check">
              <%= f.check_box :remember_me, class: "form-check-input" %>
              <%= f.label :remember_me, class: "form-check-label text-muted small" %>
            </div>
          <% end %>

          <div class="d-grid mt-4">
            <%= f.submit "Sign in", class: "btn btn-primary btn-lg" %>
          </div>
        <% end %>

        <div class="text-center mt-3 small text-muted">
          <%= link_to "Forgot your password?", new_customer_user_password_path, class: "text-muted" %>
        </div>
      </div>
    </div>
  </body>
</html>
  <body>
    <section class="hero is-primary h-100">
      <div class="hero-body">
        <div class="container">
          <div class="row justify-content-center">
            <div class="col-5-tablet is-4-desktop is-4-widescreen">

              <div class="text-center mb-5">
                <p class="fw-bold text-white">🏢 Customer Portal</p>
                <p class="subfw-bold fs-6 text-primary-light">DevTeam Hub</p>
              </div>

              <% flash.each do |type, msg| %>
                <div class="alert alert-secondary <%= type == 'alert' ? 'is-danger' : 'is-info' %> is-light mb-4">
                  <%= msg %>
                </div>
              <% end %>

              <div class="card p-3 mb-3">
                <h2 class="fw-bold fs-5 text-center mb-4">Sign in to your account</h2>

                <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "" }) do |f| %>
                  <div class="mb-3">
                    <%= f.label :email, class: "label" %>
                    <div class=" has-icons-left">
                      <%= f.email_field :email, autofocus: true, autocomplete: "email",
                            class: "input", placeholder: "your@email.com" %>
                      <span class="icon is-left">✉</span>
                    </div>
                  </div>

                  <div class="mb-3">
                    <%= f.label :password, class: "label" %>
                    <div class=" has-icons-left">
                      <%= f.password_field :password, autocomplete: "current-password",
                            class: "input", placeholder: "••••••••" %>
                      <span class="icon is-left">🔒</span>
                    </div>
                  </div>

                  <% if devise_mapping.rememberable? %>
                    <div class="mb-3">
                      <label class="checkcard p-3 mb-3">
                        <%= f.check_box :remember_me %> Remember me
                      </label>
                    </div>
                  <% end %>

                  <div class="mb-3 mt-4">
                    <%= f.submit "Sign in", class: "btn btn-primary w-100" %>
                  </div>
                <% end %>

                <div class="text-center mt-3">
                  <%= link_to "Forgot your password?", new_customer_user_password_path, class: "fs-7 text-muted" %>
                </div>
              </div>

            </div>
          </div>
        </div>
      </div>
    </section>
  </body>
</html>
