<% content_for :title, @meta[:title] %>

<div class="level mb-3">
  <div class="level-left">
    <div>
      <h1 class="fw-bold mb-1"><%= @meta[:icon] %> <%= @meta[:title] %></h1>
      <% if @sprint %>
        <p class="text-muted fs-7 mb-0"><%= @project.name %> · <%= @sprint.name %></p>
      <% end %>
    </div>
  </div>
  <div class="level-right">
    <%= render "shared/sprint_picker", sprints: @sprint_options, selected: @sprint, url: ceremony_path(@kind) %>
  </div>
</div>

<% unless @sprint %>
  <div class="alert alert-light">No active sprint. Pick one above, or set a current sprint on a project.</div>
<% else %>

  <%= render "shared/jitsi_bar", room: "devteam-#{@kind}-sprint-#{@sprint.id}", title: "#{@meta[:title]} — #{@sprint.name}" %>

  <%# ───────────────────────────── Planning ───────────────────────────── %>
  <% if @kind == "planning" %>
    <% if @goals.present? %>
      <div class="alert alert-info is-light mb-4"><strong>🎯 Sprint goal:</strong> <%= simple_format(@goals) %></div>
    <% end %>

    <div class="row g-3 mb-4">
      <div class="col-md-5">
        <div class="card p-3 h-100">
          <h2 class="fs-6 fw-bold mb-2">Team capacity</h2>
          <% @capacity.each do |member, load| %>
            <div class="d-flex align-items-center gap-2 py-1 border-bottom">
              <%= user_avatar(member, size: 24) %>
              <span class="flex-grow-1 fs-7"><%= member.display_name %></span>
              <span class="badge bg-light text-dark"><%= load %> open</span>
            </div>
          <% end %>
          <% if @capacity.empty? %><p class="text-muted fs-7 mb-0">No one assigned yet.</p><% end %>
        </div>
      </div>
      <div class="col-md-7">
        <div class="card p-3 h-100">
          <h2 class="fs-6 fw-bold mb-2">Needs estimation in this sprint <span class="text-muted">(<%= @needs_estimation.size %>)</span></h2>
          <% if @needs_estimation.any? %>
            <% @needs_estimation.each do |t| %>
              <div class="d-flex align-items-center gap-2 py-1 border-bottom fs-7">
                <%= link_to "T-#{t.id}", ticket_path(t), class: "text-decoration-none" %>
                <span class="flex-grow-1"><%= t.title.truncate(50) %></span>
                <%= link_to "Estimate →", edit_ticket_path(t), class: "btn btn-sm btn-outline-primary" %>
              </div>
            <% end %>
          <% else %>
            <p class="text-muted fs-7 mb-0">Everything in the sprint is estimated. 🎉</p>
          <% end %>
        </div>
      </div>
    </div>

    <h2 class="fs-5 fw-bold mb-2">📥 Backlog — candidates to pull in</h2>
    <%= render "ceremonies/ticket_table", tickets: @backlog, empty: "Backlog is empty.", with_pull: true %>

  <%# ──────────────────────────── Refinement ──────────────────────────── %>
  <% elsif @kind == "refinement" %>
    <p class="text-muted fs-7">Tickets missing a story-point estimate, a dev estimate, or a description — refine them so they're ready to plan. Use the AI 🤖 actions on each ticket to help.</p>
    <%= render "ceremonies/ticket_table", tickets: @to_refine, empty: "Nothing needs refinement. 🎉", with_pull: false %>

  <%# ────────────────────────────── Review ────────────────────────────── %>
  <% elsif @kind == "review" %>
    <div class="row g-3 mb-4">
      <div class="col-md-3"><div class="card p-3 text-center"><div class="fw-bold fs-4 text-success"><%= @completed.size %></div><div class="text-muted fs-7">Completed</div></div></div>
      <div class="col-md-3"><div class="card p-3 text-center"><div class="fw-bold fs-4"><%= @carryover.size %></div><div class="text-muted fs-7">Carryover</div></div></div>
      <div class="col-md-3"><div class="card p-3 text-center"><div class="fw-bold fs-4"><%= @sprint.progress_percent %>%</div><div class="text-muted fs-7">Done</div></div></div>
      <div class="col-md-3"><div class="card p-3 text-center"><div class="fw-bold fs-4"><%= @pull_requests.size %></div><div class="text-muted fs-7">Pull requests</div></div></div>
    </div>

    <h2 class="fs-5 fw-bold mb-2">✅ Shipped this sprint — demo these</h2>
    <%= render "ceremonies/ticket_table", tickets: @completed, empty: "Nothing completed yet.", with_pull: false %>

    <% if @carryover.any? %>
      <h2 class="fs-5 fw-bold mb-2 mt-4">↪️ Carrying over</h2>
      <%= render "ceremonies/ticket_table", tickets: @carryover, empty: "", with_pull: false %>
    <% end %>
  <% end %>
<% end %>
