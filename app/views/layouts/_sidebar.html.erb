<%# ── Left Sidebar ──────────────────────────────────────────────────────────── %>
<%
  # A project is "current" when the page being viewed belongs to one. Controllers
  # for project-scoped pages set @project; the AI-Agent and GitHub groups only
  # appear in that context.
  current_project = @project if defined?(@project) && @project.is_a?(Project) && @project.persisted?
%>
<aside class="app-sidebar">

  <%# Workspace header %>
  <div class="sidebar-workspace">
    <%= link_to today_path, class: "sidebar-workspace-name" do %>
      🚀 DevTeam Hub
    <% end %>
  </div>

  <%# ── פריט ראשי / Main ─────────────────────────────────────────────────── %>
  <div class="sidebar-section-label"><%= t('sidebar.main_label') %></div>

  <%= link_to today_path,
        class: "sidebar-nav-item #{controller_name == 'today' ? 'is-active' : ''}" do %>
    <span class="nav-icon">📋</span> <%= t('nav.my_day') %>
  <% end %>

  <%= link_to projects_path,
        class: "sidebar-nav-item #{controller_name == 'projects' ? 'is-active' : ''}" do %>
    <span class="nav-icon">📦</span> <%= t('nav.my_projects') %>
  <% end %>

  <%= link_to all_documents_path,
        class: "sidebar-nav-item #{controller_name == 'all_documents' ? 'is-active' : ''}" do %>
    <span class="nav-icon">📚</span> <%= t('nav.library') %>
  <% end %>

  <%= link_to attachments_path,
        class: "sidebar-nav-item #{controller_name == 'attachments' ? 'is-active' : ''}" do %>
    <span class="nav-icon">📎</span> <%= t('nav.files') %>
  <% end %>

  <hr class="sidebar-divider">

  <%# ── כלים / Tools ──────────────────────────────────────────────────────── %>
  <div class="sidebar-section-label"><%= t('sidebar.tools_label') %></div>

  <%= link_to time_logs_path,
        class: "sidebar-nav-item #{controller_name == 'time_logs' ? 'is-active' : ''}" do %>
    <span class="nav-icon">⏱️</span> <%= t('nav.time_logging') %>
  <% end %>

  <%= link_to notes_path,
        class: "sidebar-nav-item #{controller_name == 'notes' ? 'is-active' : ''}" do %>
    <span class="nav-icon">📝</span> <%= t('nav.notes') %>
  <% end %>

  <%= link_to todo_lists_path,
        class: "sidebar-nav-item #{controller_name == 'todo_lists' || controller_name == 'todo_items' ? 'is-active' : ''}" do %>
    <span class="nav-icon">✅</span> <%= t('nav.todos') %>
  <% end %>

  <%# AI Agent — only inside a project (chat is scoped to the project's repo/tickets) %>
  <% if current_project %>
    <%= link_to project_ai_chats_path(current_project),
          class: "sidebar-nav-item #{controller_name == 'ai_chats' ? 'is-active' : ''}" do %>
      <span class="nav-icon">🤖</span> <%= t('nav.ai_agent') %>
    <% end %>
  <% end %>

  <%# ── גיטהב / GitHub — only inside a project ───────────────────────────── %>
  <% if current_project %>
    <hr class="sidebar-divider">
    <div class="sidebar-section-label"><%= t('sidebar.github_label') %></div>

    <% if current_project.repo_url.present? %>
      <%= link_to current_project.repo_url, target: "_blank", rel: "noopener noreferrer",
            class: "sidebar-nav-item" do %>
        <span class="nav-icon">💻</span> <%= t('nav.github_code') %>
      <% end %>
    <% end %>

    <%= link_to project_pull_requests_path(current_project),
          class: "sidebar-nav-item #{controller_name == 'pull_requests' ? 'is-active' : ''}" do %>
      <span class="nav-icon">🔀</span> <%= t('nav.github_prs') %>
    <% end %>

    <%= link_to ci_dashboard_project_path(current_project),
          class: "sidebar-nav-item #{controller_name == 'ci_runs' ? 'is-active' : ''}" do %>
      <span class="nav-icon">🏗️</span> <%= t('nav.github_build') %>
    <% end %>

    <%= link_to report_project_path(current_project),
          class: "sidebar-nav-item #{controller_name == 'projects' && action_name == 'report' ? 'is-active' : ''}" do %>
      <span class="nav-icon">✅</span> <%= t('nav.github_tests') %>
    <% end %>

    <%= link_to project_tickets_path(current_project),
          class: "sidebar-nav-item #{controller_name == 'tickets' ? 'is-active' : ''}" do %>
      <span class="nav-icon">🎫</span> <%= t('nav.github_issues') %>
    <% end %>
  <% end %>

  <hr class="sidebar-divider">

  <%# ── טבלאות / Tables ──────────────────────────────────────────────────── %>
  <div class="sidebar-section-label"><%= t('sidebar.tables_label') %></div>

  <%= link_to customers_path,
        class: "sidebar-nav-item #{controller_name == 'customers' ? 'is-active' : ''}" do %>
    <span class="nav-icon">🏢</span> <%= t('nav.customers') %>
  <% end %>

  <% if current_user.admin? %>
    <%= link_to admin_users_path,
          class: "sidebar-nav-item #{controller_path == 'admin/users' ? 'is-active' : ''}" do %>
      <span class="nav-icon">👥</span> <%= t('nav.users') %>
    <% end %>
  <% end %>

  <%# ── User footer ──────────────────────────────────────────────────── %>
  <div class="sidebar-user">
    <% if current_user.avatar.attached? %>
      <%= user_avatar(current_user, size: 32, css_class: "sidebar-user-avatar") %>
    <% else %>
      <div class="sidebar-user-avatar"><%= current_user.initials %></div>
    <% end %>
    <div style="flex:1;min-width:0;">
      <div class="sidebar-user-name"><%= current_user.display_name %></div>
      <div class="sidebar-user-status">
        <%= link_to t('nav.profile'), edit_profile_path,
              style: "color:rgba(255,255,255,0.4);font-size:0.72rem;text-decoration:none;" %>
        &nbsp;·&nbsp;
        <%= link_to t('nav.sign_out'), destroy_user_session_path,
              data: { turbo_method: :delete },
              style: "color:rgba(255,255,255,0.4);font-size:0.72rem;text-decoration:none;" %>
      </div>
    </div>
  </div>

</aside>
