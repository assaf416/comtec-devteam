<div class="min-vh-100 d-flex align-items-center justify-content-center bg-light">
  <div class="card shadow-sm" style="width:100%;max-width:420px;">
    <div class="card-body p-4 p-md-5">
      <div class="text-center mb-4">
        <div style="font-size:2.5rem;">🚀</div>
        <h1 class="fw-bold fs-4 mt-2">DevTeam Hub</h1>
        <p class="text-muted small">Sign in to your account</p>
      </div>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div class="mb-3">
          <%= f.label :email, class: "form-label fw-semibold" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
                class: "form-control", placeholder: "you@example.com" %>
        </div>

        <div class="mb-3">
          <%= f.label :password, class: "form-label fw-semibold" %>
          <%= f.password_field :password, autocomplete: "current-password",
                class: "form-control", placeholder: "••••••••" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="mb-3 form-check">
            <%= f.check_box :remember_me, class: "form-check-input" %>
            <%= f.label :remember_me, class: "form-check-label text-muted small" %>
          </div>
        <% end %>

        <div class="d-grid mt-4">
          <%= f.submit "Sign in", class: "btn btn-primary btn-lg" %>
        </div>
      <% end %>

      <hr class="my-4">
      <div class="text-center small">
        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</div>
