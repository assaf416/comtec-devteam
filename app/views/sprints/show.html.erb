<% content_for :title, @sprint.name %>

<%= render "shared/context_bar", type: "Sprint", icon: "🏃", color: "warning",
      crumbs: [
        ["Projects", projects_path],
        [@project.name, project_path(@project)],
        ["Sprints", project_sprints_path(@project)],
        [@sprint.name, nil]
      ] %>

<%# ── Header ──────────────────────────────────────────────────────────────── %>
<div class="level">
  <div class="level-left">
    <div>
      <h1 class="fw-bold mb-1">🏃 <%= @sprint.name %></h1>
      <p class="text-muted fs-7">
        <%= @sprint.start_date.strftime("%d %b %Y") %> – <%= @sprint.end_date.strftime("%d %b %Y") %>
        · <%= @sprint.duration_days %> days
        <% if @sprint.active? %>· <strong class="text-success"><%= @sprint.days_remaining %> days remaining</strong><% end %>
      </p>
    </div>
  </div>
  <div class="level-right d-flex gap-2">
    <% status_colors = { "planning" => "bg-info", "active" => "bg-success", "completed" => "bg-secondary", "cancelled" => "bg-danger" } %>
    <% if @sprint.current? %>
      <span class="badge bg-success align-self-center">★ Current sprint</span>
    <% else %>
      <span class="badge <%= status_colors[@sprint.status] || "bg-secondary" %> align-self-center"><%= @sprint.status.humanize %></span>
      <%= button_to "★ Set as current", activate_sprint_path(@sprint), method: :patch, class: "btn btn-success btn-sm",
            form: { data: { turbo_confirm: "Make this the current sprint for #{@project.name}? The previous current sprint will be closed." } } %>
    <% end %>
    <%= link_to "📊 Dashboard", dashboard_sprint_path(@sprint), class: "btn btn-primary btn-sm is-light" %>
    <%= button_to "📊 AI Estimation", tools_ai_estimation_analysis_path(sprint_id: @sprint.id),
          method: :post, class: "btn btn-secondary btn-sm" %>
    <%= link_to t("common.actions.edit"), edit_sprint_path(@sprint), class: "btn btn-secondary btn-sm is-warning is-light" %>
    <%= button_to t("common.delete"), sprint_path(@sprint), method: :delete,
          data: { turbo_confirm: t("common.confirm_delete") }, class: "btn btn-secondary btn-sm is-danger is-light" %>
  </div>
</div>

<%# ── Top tiles ───────────────────────────────────────────────────────────── %>
<div class="row g-2 mb-4">
  <div class="col-6 col-md-3">
    <div class="card p-3 text-center"><div class="fw-bold fs-3"><%= @tickets.size %></div><div class="text-muted fs-7">Tickets</div></div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card p-3 text-center">
      <div class="fw-bold fs-3"><%= @progress %>%</div>
      <div class="text-muted fs-7">Progress (<%= @done_count %>/<%= @tickets.size %>)</div>
      <div class="progress mt-1" style="height:4px;"><div class="progress-bar bg-success" style="width:<%= @progress %>%"></div></div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card p-3 text-center"><div class="fw-bold fs-3"><%= @sprint.velocity.presence || "—" %></div><div class="text-muted fs-7">Team velocity (pts)</div></div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card p-3 text-center"><div class="fw-bold fs-3 <%= 'text-danger' if @bug_count.positive? %>"><%= @bug_count %></div><div class="text-muted fs-7">🐞 Bugs</div></div>
  </div>
</div>

<% if @sprint.goals.present? %>
  <div class="alert alert-info is-light mb-4"><strong>🎯 Goals:</strong> <%= simple_format(@sprint.goals) %></div>
<% end %>

<%# ── Live AI sprint analysis ─────────────────────────────────────────────── %>
<turbo-frame id="ai_sprint_analysis" src="<%= tools_ai_sprint_analysis_path(sprint_id: @sprint.id) %>" loading="lazy">
  <div class="card p-3 mb-4" style="border-left:4px solid #7048e8;">
    <span class="text-muted fs-7">🤖 <%= t("ai.analyzing") %> <span class="spinner-border spinner-border-sm ms-1"></span></span>
  </div>
</turbo-frame>

<%# ── Tickets (tabbed: open / completed / needs estimation) ────────────────── %>
<div class="card p-3 mb-4" id="tickets">
  <div class="level mb-3">
    <div class="level-left"><h3 class="fw-bold fs-5 mb-0">🎫 Tickets</h3></div>
    <div class="level-right"><%= link_to "All project tickets →", project_tickets_path(@project), class: "fs-7 text-muted" %></div>
  </div>

  <div class="btn-group btn-group-sm mb-3" role="group">
    <% [ [ "open", "Open" ], [ "completed", "Completed" ], [ "needs_estimation", "Needs estimation" ] ].each do |key, label| %>
      <%= link_to sprint_path(@sprint, tab: key, anchor: "tickets"),
            class: "btn #{@tab == key ? 'btn-primary' : 'btn-outline-secondary'}" do %>
        <%= label %> <span class="badge bg-light text-dark"><%= @tab_counts[key] %></span>
      <% end %>
    <% end %>
  </div>

  <% if @tab_tickets.any? %>
    <table class="table table-hover align-middle mb-0 fs-7">
      <thead><tr><th>#</th><th>Title</th><th>Status</th><th>People</th><th>Progress</th><th class="text-end"></th></tr></thead>
      <tbody>
        <% @tab_tickets.each do |ticket| %>
          <tr style="cursor:pointer;" onclick="window.location='<%= ticket_path(ticket) %>'">
            <td class="text-muted"><%= ticket.id %></td>
            <td class="fw-semibold"><%= ticket.title.truncate(54) %></td>
            <td><%= status_tag(ticket.status) %></td>
            <td><%= render "tickets/people", ticket: ticket, size: 22 %></td>
            <td><%= render "tickets/progress_cell", ticket: ticket %></td>
            <td class="text-end" onclick="event.stopPropagation();" style="cursor:default;">
              <% if @tab == "needs_estimation" %>
                <%= link_to "Refine →", edit_ticket_path(ticket), class: "btn btn-outline-primary btn-sm" %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-muted fs-7 mb-0">No tickets in this view.</p>
  <% end %>
</div>

<%# ── Sprint comments (note / green card / red card) ───────────────────────── %>
<div class="card p-3 mb-4" id="comments">
  <h3 class="fw-bold fs-5 mb-3">💬 Sprint comments (<%= @comments.size %>)</h3>

  <% @comments.each do |comment| %>
    <% m = comment.kind_meta %>
    <div class="d-flex gap-2 mb-2 p-2" id="comment-<%= comment.id %>"
         style="border-left:4px solid <%= m[:border] %>;background:<%= m[:bg] %>;border-radius:0 8px 8px 0;">
      <div class="fs-5 flex-shrink-0"><%= m[:icon] %></div>
      <div class="flex-grow-1">
        <div class="fs-7">
          <strong><%= comment.author&.display_name || "System" %></strong>
          <% unless comment.kind_note? %>
            <span class="badge" style="background:<%= m[:border] %>;color:#fff;"><%= m[:label] %></span>
          <% end %>
          <span class="text-muted ms-1"><%= time_ago_in_words(comment.created_at) %> ago</span>
        </div>
        <div class="fs-7"><%= simple_format(h(comment.body)) %></div>
      </div>
      <% if comment.author == current_user || current_user.admin? %>
        <%= button_to "✕", sprint_comment_path(@sprint, comment), method: :delete,
              data: { turbo_confirm: "Delete this comment?" }, class: "btn-close flex-shrink-0" %>
      <% end %>
    </div>
  <% end %>
  <% if @comments.empty? %><p class="text-muted fs-7">No comments yet.</p><% end %>

  <hr>
  <%= form_with url: sprint_comments_path(@sprint), method: :post do %>
    <div class="mb-2"><textarea name="comment[body]" class="form-control" rows="2" placeholder="Add a comment…" required></textarea></div>
    <div class="d-flex gap-2 align-items-center">
      <%= render "comments/kind_select" %>
      <%= submit_tag "Comment", class: "btn btn-primary btn-sm" %>
    </div>
  <% end %>
</div>

<%# ── Pull requests in this sprint ─────────────────────────────────────────── %>
<div class="card p-3 mb-4">
  <h3 class="fw-bold fs-5 mb-3">🔀 Pull Requests (<%= @pull_requests.count %>)</h3>
  <% if @pull_requests.any? %>
    <table class="table w-100 fs-7 align-middle mb-0">
      <thead><tr><th><%= t('table_headers.id') %></th><th><%= t('table_headers.title') %></th><th><%= t('table_headers.ticket') %></th><th><%= t('table_headers.status') %></th><th>Opened</th></tr></thead>
      <tbody>
        <% @pull_requests.each do |pr| %>
          <tr>
            <td><code>#<%= pr.pr_number %></code></td>
            <td><%= pr.gitea_url.present? ? link_to(pr.title.truncate(50), pr.gitea_url, target: "_blank", rel: "noopener") : pr.title.truncate(50) %></td>
            <td><% if pr.ticket %><%= link_to pr.ticket.title.truncate(30), ticket_path(pr.ticket) %><% else %>—<% end %></td>
            <td><%= status_tag(pr.status) %></td>
            <td class="text-muted"><%= pr.created_at.strftime("%d %b") %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-muted fs-7 mb-0">No pull requests linked to this sprint yet.</p>
  <% end %>
</div>

<%# ── Documents created in this sprint ─────────────────────────────────────── %>
<div class="card p-3 mb-4">
  <h3 class="fw-bold fs-5 mb-3">📁 Sprint documents (<%= @documents.size %>)</h3>
  <% if @documents.any? %>
    <table class="table table-hover w-100 fs-7 align-middle mb-0">
      <thead><tr><th>Title</th><th>Type</th><th>Author</th><th>Updated</th></tr></thead>
      <tbody>
        <% @documents.each do |doc| %>
          <tr style="cursor:pointer;" onclick="window.location='<%= document_path(doc) %>'">
            <td class="fw-semibold"><%= doc.title %></td>
            <td><span class="badge bg-light text-dark border"><%= t("documents.types.#{doc.doc_type}", default: doc.doc_type.to_s.humanize) %></span></td>
            <td><%= doc.author&.display_name || "—" %></td>
            <td class="text-muted"><%= doc.updated_at.strftime("%d %b %Y") %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-muted fs-7 mb-0">No documents created in this sprint yet.</p>
  <% end %>
</div>

<%# ── Secondary: team · meetings · retro notes ─────────────────────────────── %>
<div class="row">
  <div class="col-md-6">
    <div class="card p-3 mb-3">
      <h5 class="fw-semibold mb-2">👥 Sprint team (<%= @sprint.participants.size %>)</h5>
      <div class="d-flex flex-wrap gap-2">
        <% @sprint.participants.each do |member| %>
          <span class="d-inline-flex align-items-center gap-1 badge bg-light text-dark border" style="padding:.4rem .6rem;">
            <%= user_avatar(member, size: 20) %> <%= member.display_name %>
          </span>
        <% end %>
        <% if @sprint.participants.empty? %><span class="text-muted fs-7">No people on this sprint yet.</span><% end %>
      </div>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card p-3 mb-3">
      <div class="d-flex align-items-center mb-2">
        <h5 class="fw-semibold mb-0">📅 Meetings (<%= @meetings.count %>)</h5>
        <%= link_to "Schedule", new_meeting_path(sprint_id: @sprint.id), class: "btn btn-outline-primary btn-sm ms-auto" %>
      </div>
      <% @meetings.each do |meeting| %>
        <div class="d-flex justify-content-between align-items-start py-1 border-bottom">
          <div>
            <p class="fw-semibold fs-7 mb-0"><%= link_to meeting.title.truncate(35), meeting_path(meeting) %></p>
            <p class="text-muted fs-7 mb-0"><%= meeting.scheduled_at&.strftime("%d %b, %H:%M") %></p>
          </div>
          <%= status_tag(meeting.status) %>
        </div>
      <% end %>
      <% if @meetings.empty? %><p class="text-muted fs-7 mb-0">No meetings linked.</p><% end %>
    </div>
  </div>
</div>
