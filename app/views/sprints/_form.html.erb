<%= form_with(model: sprint.new_record? ? [@project, sprint] : sprint, html: { class: "card p-3 mb-3" }) do |f| %>
  <% if sprint.errors.any? %>
    <div class="alert alert-danger is-light">
      <ul><% sprint.errors.full_messages.each do |m| %><li><%= m %></li><% end %></ul>
    </div>
  <% end %>

  <div class="row">
    <div class="col-8">
      <div class="mb-3">
        <%= f.label :name, class: "label" %>
        <%= f.text_field :name, class: "form-control", required: true, placeholder: "Sprint 1 — Auth & Onboarding" %>
      </div>
    </div>
    <div class="col-4">
      <div class="mb-3">
        <%= f.label :status, class: "label" %>
        <%= f.select :status, Sprint.statuses.keys.map { |s| [s.humanize, s] }, {}, class: "form-select" %>
      </div>
    </div>
  </div>

  <div class="row">
    <div class="col-4">
      <div class="mb-3">
        <%= f.label :start_date, "Start Date", class: "label" %>
        <%= f.date_field :start_date, class: "form-control", required: true %>
      </div>
    </div>
    <div class="col-4">
      <div class="mb-3">
        <%= f.label :end_date, "End Date", class: "label" %>
        <%= f.date_field :end_date, class: "form-control", required: true %>
      </div>
    </div>
    <div class="col-4">
      <div class="mb-3">
        <%= f.label :velocity, "Planned Velocity (pts)", class: "label" %>
        <%= f.number_field :velocity, class: "form-control", min: 0 %>
      </div>
    </div>
  </div>

  <div class="mb-3">
    <%= f.label :goals, "Sprint Goals", class: "label" %>
    <%= f.text_area :goals, class: "form-control", rows: 3, placeholder: "What should be achieved in this sprint?" %>
  </div>

  <div class="row">
    <div class="col-md-6">
      <div class="mb-3">
        <%= f.label :things_that_went_right, "Things That Went Right", class: "label" %>
        <%= f.hidden_field :things_that_went_right, id: "sprint_things_that_went_right_input" %>
        <trix-editor input="sprint_things_that_went_right_input" class="trix-content" style="min-height:140px;"></trix-editor>
      </div>
    </div>
    <div class="col-md-6">
      <div class="mb-3">
        <%= f.label :things_to_improve, "Things to Improve", class: "label" %>
        <%= f.hidden_field :things_to_improve, id: "sprint_things_to_improve_input" %>
        <trix-editor input="sprint_things_to_improve_input" class="trix-content" style="min-height:140px;"></trix-editor>
      </div>
    </div>
  </div>

  <script>
    document.addEventListener("trix-initialize", function(event) {
      var editor = event.target;
      var inputId = editor.getAttribute("input");
      var hidden = document.getElementById(inputId);
      if (hidden && hidden.value) { editor.editor.loadHTML(hidden.value); }
    });
  </script>

  <div class="d-flex gap-2">
    <%= f.submit sprint.new_record? ? "Create Sprint" : "Update Sprint", class: "btn btn-primary" %>
    <% if sprint.new_record? %>
      <%= link_to "Cancel", project_sprints_path(@project), class: "btn btn-secondary" %>
    <% else %>
      <%= link_to "Cancel", sprint_path(sprint), class: "btn btn-secondary" %>
    <% end %>
  </div>
<% end %>
