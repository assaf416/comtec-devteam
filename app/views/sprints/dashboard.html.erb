<% content_for :title, "#{@sprint.name} · Dashboard" %>

<div class="level mb-3">
  <div class="level-left">
    <div>
      <nav class="breadcrumb is-small"><ul>
        <li><%= link_to @project.name, @project %></li>
        <li><%= link_to "Sprints", project_sprints_path(@project) %></li>
        <li><%= link_to @sprint.name, @sprint %></li>
        <li class="is-active"><a>Dashboard</a></li>
      </ul></nav>
      <h1 class="fw-bold mb-1">📊 <%= @sprint.name %> — Dashboard</h1>
      <p class="text-muted fs-7">
        <%= @sprint.start_date.strftime("%d %b") %> – <%= @sprint.end_date.strftime("%d %b %Y") %>
        · <%= @sprint.status.humanize %>
      </p>
    </div>
  </div>
  <div class="level-right">
    <%= link_to "← Back to sprint", @sprint, class: "btn btn-secondary btn-sm" %>
  </div>
</div>

<%# ── Stat cards ──────────────────────────────────────────────────────── %>
<div class="row g-2 mb-4">
  <div class="col-6 col-md-3">
    <div class="card p-3 text-center"><div class="fw-bold fs-4"><%= @total_tickets %></div><div class="text-muted fs-7">Tickets</div></div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card p-3 text-center">
      <div class="fw-bold fs-4"><%= @progress_percent %>%</div>
      <div class="text-muted fs-7">Done</div>
      <div class="progress mt-1" style="height:4px;"><div class="progress-bar bg-success" style="width:<%= @progress_percent %>%"></div></div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card p-3 text-center"><div class="fw-bold fs-4"><%= @in_progress %></div><div class="text-muted fs-7">In progress</div></div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card p-3 text-center"><div class="fw-bold fs-4"><%= @not_started %></div><div class="text-muted fs-7">Not started</div></div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card p-3 text-center"><div class="fw-bold fs-4 <%= 'text-danger' if @blocked.positive? %>"><%= @blocked %></div><div class="text-muted fs-7">Blocked</div></div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card p-3 text-center"><div class="fw-bold fs-4"><%= @points_done %>/<%= @points_total %></div><div class="text-muted fs-7">Story points</div></div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card p-3 text-center"><div class="fw-bold fs-4"><%= @sprint.days_remaining %></div><div class="text-muted fs-7">Days left</div></div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card p-3 text-center">
      <div class="fw-bold fs-4"><%= @task_progress_percent %>%</div>
      <div class="text-muted fs-7">Task progress</div>
      <div class="progress mt-1" style="height:4px;"><div class="progress-bar bg-info" style="width:<%= @task_progress_percent %>%"></div></div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card p-3 text-center"><div class="fw-bold fs-4"><%= @task_estimation_total %>h</div><div class="text-muted fs-7">Task estimation</div></div>
  </div>
</div>

<%= render "shared/insights", insights: @insights %>

<%# ── Live AI sprint analysis (lazy-loaded from the local Ollama LLM) ───── %>
<turbo-frame id="ai_sprint_analysis"
             src="<%= tools_ai_sprint_analysis_path(sprint_id: @sprint.id) %>"
             loading="lazy">
  <div class="card p-3 mb-4" style="border-left:4px solid #7048e8;">
    <span class="text-muted fs-7">🤖 <%= t("ai.analyzing") %> <span class="spinner-border spinner-border-sm ms-1"></span></span>
  </div>
</turbo-frame>

<div class="row">
  <div class="col-lg-7"><%= render "shared/ticket_status_breakdown", counts: @status_counts, total: @total_tickets %></div>
  <div class="col-lg-5">
    <div class="card p-3 mb-4">
      <h2 class="fs-6 fw-bold mb-2">Open work by assignee</h2>
      <% if @workload.any? %>
        <% @workload.each do |name, count| %>
          <div class="d-flex justify-content-between fs-7 py-1 border-bottom"><span><%= name %></span><span class="badge bg-light text-dark"><%= count %></span></div>
        <% end %>
      <% else %>
        <p class="text-muted fs-7 mb-0">No assigned open work.</p>
      <% end %>
    </div>
  </div>
</div>
