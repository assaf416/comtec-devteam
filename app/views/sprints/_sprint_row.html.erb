<div class="card p-3 mb-2">
  <div class="d-flex align-items-center justify-content-between">
    <div>
      <p class="fw-semibold mb-0"><%= link_to sprint.name, sprint_path(sprint) %></p>
      <p class="text-muted fs-7 mb-0">
        <%= sprint.start_date.strftime("%d %b") %> – <%= sprint.end_date.strftime("%d %b %Y") %>
        · <%= sprint.tickets.count %> tickets
        <% if sprint.velocity.present? %>· <%= sprint.velocity %> pts velocity<% end %>
      </p>
    </div>
    <div>
      <%= actions_dropdown do |d| %>
        <% d.link t('common.view'), sprint_path(sprint), icon: '👁' %>
        <% unless sprint.current? %>
          <% d.button_action "Set as current", activate_sprint_path(sprint), icon: '★',
                confirm: "Make \"#{sprint.name}\" the current sprint? The previous current sprint will be closed." %>
        <% end %>
        <% d.link t('common.actions.edit'), edit_sprint_path(sprint), icon: '✏️' %>
        <% d.divider %>
        <% d.delete t('common.delete'), sprint_path(sprint), confirm: t('common.confirm_delete') %>
      <% end %>
    </div>
  </div>
</div>
