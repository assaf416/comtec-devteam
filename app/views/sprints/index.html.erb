<% content_for :title, "Sprints — #{@project.name}" %>

<div class="level">
  <div class="level-left">
    <div>
      <nav class="breadcrumb is-small"><ul>
        <li><%= link_to @project.name, @project %></li>
        <li class="is-active"><a>Sprints</a></li>
      </ul></nav>
      <h1 class="fw-bold">Sprints — <%= @project.name %></h1>
    </div>
  </div>
  <div class="level-right">
    <%= link_to t("buttons.new_sprint"), new_project_sprint_path(@project), class: "btn btn-primary" %>
  </div>
</div>

<% if @active_sprint %>
  <div class="card border-success p-3 mb-4">
    <div class="d-flex align-items-center justify-content-between">
      <div>
        <span class="badge bg-success mb-1">Active Sprint</span>
        <h3 class="fw-bold mb-1"><%= link_to @active_sprint.name, @active_sprint %></h3>
        <p class="text-muted fs-7 mb-0">
          <%= @active_sprint.start_date.strftime("%d %b") %> – <%= @active_sprint.end_date.strftime("%d %b %Y") %>
          · <%= @active_sprint.days_remaining %> days remaining
          · <%= @active_sprint.tickets.count %> tickets
        </p>
      </div>
      <div class="text-end">
        <div class="fw-bold fs-5"><%= @active_sprint.progress_percent %>%</div>
        <div class="progress" style="width:120px;height:8px;">
          <div class="progress-bar bg-success" style="width:<%= @active_sprint.progress_percent %>%"></div>
        </div>
        <div class="fs-7 text-muted mt-1">complete</div>
      </div>
    </div>
  </div>
<% end %>

<% if @planning_sprints.any? %>
  <h5 class="fw-semibold text-muted mb-2">📋 Planning</h5>
  <%= render partial: "sprint_row", collection: @planning_sprints, as: :sprint %>
<% end %>

<% if @done_sprints.any? %>
  <h5 class="fw-semibold text-muted mb-2 mt-4">✅ Completed</h5>
  <%= render partial: "sprint_row", collection: @done_sprints, as: :sprint %>
<% end %>

<% if @sprints.empty? %>
  <div class="alert alert-light">
    No sprints yet. <%= link_to "Create the first one", new_project_sprint_path(@project) %>.
  </div>
<% end %>
