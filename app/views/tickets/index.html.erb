<% content_for :title, "Tickets – #{@project.name}" %>

<div class="level">
  <div class="level-left">
    <h1 class="fw-bold"><%= @project.name %> — Tickets</h1>
  </div>
  <div class="level-right">
    <% if GithubService.github_url?(@project.repo_url) %>
      <%= button_to "🔄 Sync GitHub issues", sync_issues_project_path(@project), method: :post, class: "btn btn-primary" %>
    <% end %>
  </div>
</div>

<%# Filter bar %>
<div class="card p-3 mb-4">
  <%= form_with url: project_tickets_path(@project), method: :get, data: { turbo_frame: "tickets_list" } do |f| %>
    <div class="d-flex gap-2 align-items-end d-flex-wrap-wrap">
      <div class="">
        <%= f.select :status, Ticket.statuses.keys.map { |s| [t("tickets.statuses.#{s}"), s] }.unshift(['All Statuses', '']),
            { selected: params[:status] }, class: "select is-small" %>
      </div>
      <div class="">
        <%= f.check_box :mine, { checked: params[:mine] == 'true', class: "checkcard p-3 mb-3" } %>
        <label class="checkcard p-3 mb-3 ms-1">My tickets only</label>
      </div>
      <div class="">
        <%= f.text_field :tag, value: params[:tag], placeholder: "Filter by tag", class: "input is-small", style: "width:160px" %>
      </div>
      <div class="">
        <%= f.submit "Filter", class: "btn btn-secondary btn-sm is-light" %>
      </div>
    </div>
  <% end %>
</div>

<%# Kanban Board %>
<div class="kanban-board" id="kanban-board">
  <% Ticket.statuses.keys.each do |status_key| %>
    <% status_tickets = @tickets.select { |t| t.status == status_key } %>
    <div class="kanban-col">
      <div class="kanban-col-fw-bold">
        <%= t("tickets.statuses.#{status_key}") %>
        <span class="badge bg-secondary is-light ms-1"><%= status_tickets.count %></span>
      </div>
      <% status_tickets.each do |ticket| %>
        <div class="kanban-card" onclick="window.location='<%= ticket_path(ticket) %>'">
          <div class="d-flex justify-content-between mb-1">
            <span class="fs-7 text-muted">#<%= ticket.id %></span>
            <%= priority_tag(ticket.priority) %>
          </div>
          <p class="fs-7 fw-semibold"><%= ticket.title %></p>
          <div class="d-flex flex-wrap gap-1 my-1"><%= render "tickets/progress_badges", ticket: ticket %></div>
          <div class="d-flex align-items-center gap-1 mt-1">
            <%= render "tickets/people", ticket: ticket, size: 22 %>
            <% if ticket.assignee %><span class="fs-7 text-muted"><%= ticket.assignee.display_name %></span><% end %>
          </div>
          <% if ticket.branch_name.present? %>
            <p class="fs-7 text-muted"><code class="fs-7"><%= ticket.branch_name %></code></p>
          <% end %>
          <% if (ci = ticket.latest_ci_run) %>
            <div class="mt-1"><%= status_tag(ci.status) %> CI</div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
