<% content_for :title, "Tickets – #{@project.name}" %>

<div class="level">
  <div class="level-left">
    <h1 class="fw-bold"><%= @project.name %> — Tickets</h1>
  </div>
  <div class="level-right">
    <% if GithubService.github_url?(@project.repo_url) %>
      <%= button_to "🔄 Sync GitHub issues", sync_issues_project_path(@project), method: :post, class: "btn btn-primary" %>
    <% end %>
  </div>
</div>

<%# Filter bar %>
<div class="card p-3 mb-4">
  <%= form_with url: project_tickets_path(@project), method: :get, data: { turbo_frame: "tickets_list" } do |f| %>
    <div class="d-flex gap-2 align-items-end d-flex-wrap-wrap">
      <div class="">
        <%= f.select :status, Ticket.statuses.keys.map { |s| [t("tickets.statuses.#{s}"), s] }.unshift(['All Statuses', '']),
            { selected: params[:status] }, class: "select is-small" %>
      </div>
      <div class="">
        <%= f.check_box :mine, { checked: params[:mine] == 'true', class: "checkcard p-3 mb-3" } %>
        <label class="checkcard p-3 mb-3 ms-1">My tickets only</label>
      </div>
      <div class="">
        <%= f.text_field :tag, value: params[:tag], placeholder: "Filter by tag", class: "input is-small", style: "width:160px" %>
      </div>
      <div class="">
        <%= f.submit "Filter", class: "btn btn-secondary btn-sm is-light" %>
      </div>
    </div>
  <% end %>
</div>

<%# Tickets table %>
<turbo-frame id="tickets_list">
  <div class="card p-0">
    <% if @tickets.empty? %>
      <p class="text-muted p-3 mb-0"><%= t("tickets.filtered.empty") %></p>
    <% else %>
      <table class="table table-striped table-hover align-middle mb-0">
        <thead>
          <tr>
            <th><%= t("table_headers.id") %></th>
            <th><%= t("table_headers.title") %></th>
            <th><%= t("table_headers.status") %></th>
            <th><%= t("table_headers.priority") %></th>
            <th><%= t("table_headers.assignee") %></th>
            <th><%= t("table_headers.branch") %></th>
          </tr>
        </thead>
        <tbody>
          <% @tickets.each do |ticket| %>
            <tr style="cursor:pointer;" onclick="window.location='<%= ticket_path(ticket) %>'">
              <td class="text-muted">#<%= ticket.id %></td>
              <td>
                <span class="fw-semibold"><%= ticket.title %></span>
                <div class="d-flex flex-wrap gap-1 mt-1"><%= render "tickets/progress_badges", ticket: ticket %></div>
              </td>
              <td><span class="badge bg-secondary is-light"><%= t("tickets.statuses.#{ticket.status}") %></span></td>
              <td><%= priority_tag(ticket.priority) %></td>
              <td>
                <div class="d-flex align-items-center gap-1">
                  <%= render "tickets/people", ticket: ticket, size: 22 %>
                  <% if ticket.assignee %><span class="fs-7"><%= ticket.assignee.display_name %></span><% end %>
                </div>
              </td>
              <td><% if ticket.branch_name.present? %><code class="fs-7"><%= ticket.branch_name %></code><% end %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>
  </div>
</turbo-frame>
