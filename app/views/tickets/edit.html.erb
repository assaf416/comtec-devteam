<div class="level mb-2">
  <div class="level-left"><h1 class="fw-bold mb-0">Edit Ticket #<%= @ticket.id %></h1></div>
  <div class="level-right">
    <% if @ticket.approved? %>
      <span class="badge bg-success">✓ Approved <%= @ticket.approved_at.strftime("%d %b %Y") %></span>
    <% else %>
      <%= button_to "✓ Approve ticket", approve_ticket_path(@ticket), method: :patch, class: "btn btn-success btn-sm" %>
    <% end %>
  </div>
</div>

<% unless @ticket.approved? %>
  <div class="alert alert-light fs-7">Draft stage — fill in the basics, then <strong>approve</strong> the ticket to refine and estimate it.</div>
<% end %>

<%# Switch between the short specs form and the short estimation form. %>
<ul class="nav nav-pills mb-3">
  <li class="nav-item">
    <%= link_to "📝 Specs", edit_ticket_path(@ticket, section: "specs"),
          class: "nav-link #{'active' if @section == 'specs'}" %>
  </li>
  <li class="nav-item">
    <%= link_to "📊 Estimation", edit_ticket_path(@ticket, section: "estimation"),
          class: "nav-link #{'active' if @section == 'estimation'}" %>
  </li>
</ul>

<%= render "form", ticket: @ticket, section: @section %>

<% if @ticket.estimated? %>
  <div class="d-flex align-items-center mb-2 mt-4">
    <h2 class="fs-5 fw-bold mb-0">🧩 Tasks</h2>
    <%= button_to "🤖 Generate tasks & estimations", tools_ai_generate_tasks_path(ticket_id: @ticket.id),
          method: :post, class: "btn btn-sm btn-outline-primary ms-auto" %>
  </div>
  <p class="text-muted fs-7">This ticket is estimated — break it into tasks (or let the AI generate them with calibrated estimates).</p>
  <%= render "tickets/tasks", ticket: @ticket %>
<% end %>
