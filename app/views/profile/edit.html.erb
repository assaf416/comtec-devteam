<% content_for(:title) { t("profile.edit_title") } %>
<% content_for(:page_title) { t("profile.edit_title") } %>

<div class="row justify-content-center">
  <div class="col-md-7 col-lg-6">

    <%# Avatar + name header %>
    <div class="card shadow-sm mb-4">
      <div class="card-body d-flex align-items-center gap-3">
        <%= user_avatar(current_user, size: 56) %>
        <div>
          <div class="fw-bold fs-5"><%= current_user.display_name %></div>
          <div class="text-muted small"><%= t("users.roles.#{current_user.role}") %></div>
        </div>
      </div>
    </div>

    <%# Profile form %>
    <%= simple_form_for @user, url: profile_path, method: :patch,
          wrapper: :vertical_form,
          html: { class: "card shadow-sm" } do |f| %>

      <div class="card-header fw-semibold">
        <%= t("profile.edit_title") %>
      </div>

      <div class="card-body">

        <% if @user.errors.any? %>
          <div class="alert alert-danger">
            <ul class="mb-0">
              <% @user.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <%# Name %>
        <%= f.input :name,
              label: t("profile.name"),
              input_html: { class: "form-control" },
              wrapper_html: { class: "mb-3" } %>

        <%# Avatar upload %>
        <div class="mb-3">
          <label class="form-label fw-semibold"><%= t("profile.avatar", default: "Avatar") %></label>
          <div class="d-flex align-items-center gap-3 mb-2">
            <%= user_avatar(current_user, size: 48) %>
            <span class="text-muted small">
              <% if current_user.avatar.attached? %>
                <%= current_user.avatar.filename %>
              <% else %>
                <%= t("profile.no_avatar", default: "No avatar uploaded") %>
              <% end %>
            </span>
          </div>
          <%= f.input :avatar,
                as: :file,
                label: false,
                input_html: { class: "form-control", accept: "image/png,image/jpeg,image/gif,image/webp,image/svg+xml" },
                hint: t("profile.avatar_hint", default: "PNG, JPEG, GIF or WebP — max 5 MB") %>
        </div>

        <%# Email (read-only) %>
        <%= f.input :email,
              label: t("profile.email"),
              input_html: { class: "form-control", disabled: true },
              wrapper_html: { class: "mb-3" },
              hint: nil %>

        <%# Language %>
        <%= f.input :preferred_language,
              label: t("profile.language"),
              as: :select,
              collection: [
                [t("profile.language_en"), "en"],
                [t("profile.language_he"), "he"]
              ],
              include_blank: false,
              input_html: { class: "form-select" },
              wrapper_html: { class: "mb-3" } %>

        <%# Password change section %>
        <hr>
        <p class="fw-semibold text-muted small mb-3"><%= t("profile.password_section") %></p>
        <p class="text-muted small mb-3"><%= t("profile.leave_blank") %></p>

        <%= f.input :current_password,
              label: t("profile.current_password"),
              as: :password,
              autocomplete: "current-password",
              input_html: { class: "form-control" },
              wrapper_html: { class: "mb-3" } %>

        <%= f.input :password,
              label: t("profile.new_password"),
              as: :password,
              autocomplete: "new-password",
              input_html: { class: "form-control" },
              wrapper_html: { class: "mb-3" } %>

        <%= f.input :password_confirmation,
              label: t("profile.confirm_password"),
              as: :password,
              autocomplete: "new-password",
              input_html: { class: "form-control" },
              wrapper_html: { class: "mb-3" } %>

      </div>

      <div class="card-footer d-flex justify-content-end">
        <%= f.submit t("profile.save"), class: "btn btn-primary" %>
      </div>

    <% end %>

  </div>
</div>
