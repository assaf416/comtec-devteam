<%= form_with(model: document.new_record? ? [@project, document] : document, html: { class: "card p-3 mb-3" }) do |f| %>
  <% if document.errors.any? %>
    <div class="alert alert-danger is-light">
      <ul><% document.errors.full_messages.each do |m| %><li><%= m %></li><% end %></ul>
    </div>
  <% end %>

  <%# Template badge / notice %>
  <% if document.is_template? %>
    <div class="alert alert-warning d-flex align-items-center gap-2 mb-3 py-2">
      <i class="bi bi-file-earmark-code fs-5"></i>
      <span>You are editing a <strong>template</strong>. Changes here will affect all future documents created from it.</span>
    </div>
  <% end %>

  <%# Hidden template_id if created from a template %>
  <%= f.hidden_field :template_id if document.template_id.present? %>

  <div class="row">
    <div class="col-8">
      <div class="mb-3">
        <%= f.label :title, class: "label" %>
        <div class=""><%= f.text_field :title, class: "input form-control", required: true %></div>
      </div>
    </div>
    <div class="col-2">
      <div class="mb-3">
        <%= f.label :doc_type, "Type", class: "label" %>
        <div class="">
          <div class="select w-100">
            <%= f.select :doc_type, Document.doc_types.keys.map { |d| [t("documents.types.#{d}"), d] }, {}, class: "form-select" %>
          </div>
        </div>
      </div>
    </div>
    <div class="col-2">
      <div class="mb-3">
        <%= f.label :version_number, "Version", class: "label" %>
        <div class=""><%= f.text_field :version_number, class: "input form-control", placeholder: "1.0" %></div>
      </div>
    </div>
  </div>

  <div class="mb-3">
    <%= f.label :summary, "Summary (one line)", class: "label" %>
    <div class=""><%= f.text_field :summary, class: "input form-control" %></div>
  </div>

  <%# Hidden input that Trix writes into — Rails receives document[content] as HTML %>
  <div class="mb-3">
    <%= f.label :content, "Content", class: "label" %>
    <%= f.hidden_field :content, id: "document_content_input" %>
    <trix-editor input="document_content_input" class="trix-editor-field"></trix-editor>
    <p class="form-text text-muted mt-1">Use the toolbar above to format your document — bold, headings, lists, links and more.</p>
  </div>

  <div class="mb-3">
    <%= f.label :tag_list, "Tags (comma separated)", class: "label" %>
    <div class=""><%= f.text_field :tag_list, value: document.tag_list.to_s, class: "input form-control" %></div>
  </div>

  <%# Save as Template checkbox %>
  <div class="mb-3 border rounded p-3 bg-light">
    <div class="form-check">
      <%= f.check_box :is_template, class: "form-check-input", id: "doc_is_template" %>
      <%= f.label :is_template, class: "form-check-label fw-semibold", for: "doc_is_template" do %>
        <i class="bi bi-file-earmark-code me-1 text-warning"></i><%= t("buttons.save_as_template") %>
      <% end %>
    </div>
    <small class="text-muted">Templates can be reused to quickly create new documents with the same structure.</small>
  </div>

  <div class="d-flex gap-2 align-items-end">
    <div class=""><%= f.submit t("common.actions.save"), class: "btn btn-primary" %></div>
    <div class=""><%= link_to "Cancel", project_documents_path(@project), class: "btn btn-secondary" %></div>
  </div>
<% end %>

<script>
  // Populate Trix editor with existing content on page load
  document.addEventListener("trix-initialize", function(event) {
    const editor = event.target
    const hiddenInput = document.getElementById("document_content_input")
    if (hiddenInput && hiddenInput.value && hiddenInput.value.trim() !== "") {
      editor.editor.loadHTML(hiddenInput.value)
    }
  })
</script>
