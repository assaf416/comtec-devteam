<%# AI document generation for a project. locals: project %>
<div class="d-flex flex-wrap gap-2 align-items-start mb-3">
  <%= button_to "🤖 Status Presentation",
        generate_project_documents_path(project, kind: "presentation"),
        method: :post, class: "btn btn-sm btn-outline-primary",
        data: { turbo_submits_with: "Generating…" } %>

  <details>
    <summary class="btn btn-sm btn-outline-primary">🤖 Generate Spec</summary>
    <%= form_with url: generate_project_documents_path(project), method: :post, class: "mt-2 d-flex gap-2 flex-wrap" do %>
      <%= hidden_field_tag :kind, "spec" %>
      <input type="text" name="topic" class="form-control form-control-sm" style="min-width:220px;"
             placeholder="Optional focus (e.g. Checkout flow)">
      <%= submit_tag "Generate spec", class: "btn btn-sm btn-primary", data: { turbo_submits_with: "Generating…" } %>
    <% end %>
  </details>

  <span class="text-muted fs-7 align-self-center">Generated by the on-prem local LLM.</span>
</div>
