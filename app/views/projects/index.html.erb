<% content_for :title, t('nav.projects') %>

<div class="level mb-3">
  <div class="level-left"><h1 class="fw-bold"><%= t('nav.projects') %></h1></div>
  <div class="level-right"><%= link_to t("buttons.new_project"), new_project_path, class: "btn btn-primary" %></div>
</div>

<% if @projects.any? %>
  <div class="card">
    <table class="table table-hover align-middle mb-0">
      <thead>
        <tr>
          <th>Project</th>
          <th>Tech stack</th>
          <th class="text-center">Open tickets</th>
          <th class="text-center">CI (7d)</th>
          <th class="text-end"></th>
        </tr>
      </thead>
      <tbody>
        <% @projects.each do |project| %>
          <% passed = project.ci_runs.passed.where(created_at: 7.days.ago..Time.current).count %>
          <% failing = project.ci_runs.failed.where(created_at: 1.day.ago..Time.current).any? %>
          <tr style="cursor:pointer;" onclick="window.location='<%= project_path(project) %>'">
            <td>
              <div class="fw-semibold"><%= project.name %></div>
              <% unless project.active? %><span class="badge bg-secondary">Archived</span><% end %>
              <div class="text-muted fs-7"><%= project.description&.truncate(70) %></div>
            </td>
            <td class="fs-7 text-muted"><%= project.tech_stack %></td>
            <td class="text-center"><%= project.tickets.where.not(status: [ :done, :closed ]).count %></td>
            <td class="text-center">
              <% if failing %>
                <span class="badge bg-danger">⚠ Failing</span>
              <% else %>
                <span class="badge bg-success-subtle text-success"><%= passed %> passed</span>
              <% end %>
            </td>
            <td class="text-end" onclick="event.stopPropagation();" style="cursor:default;">
              <%= actions_dropdown do |d| %>
                <% d.link t('common.view'), project_path(project), icon: '👁' %>
                <% d.link "Dashboard", dashboard_project_path(project), icon: '📊' %>
                <% d.link "Tickets", project_tickets_path(project), icon: '🎫' %>
                <% d.link "CI", ci_dashboard_project_path(project), icon: '🏗️' %>
                <% d.link "Deployments", project_deployments_path(project), icon: '🚀' %>
                <% d.divider %>
                <% d.link t('common.actions.edit'), edit_project_path(project), icon: '✏️' %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="card p-5 text-center text-muted">
    <p class="mb-2">No projects yet.</p>
    <div><%= link_to t("buttons.new_project"), new_project_path, class: "btn btn-primary btn-sm" %></div>
  </div>
<% end %>
