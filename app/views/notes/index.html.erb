<% content_for :title, t("notes.title") %>

<div class="level mb-3">
  <div class="level-left"><h1 class="fw-bold">📝 <%= t("notes.title") %></h1></div>
  <div class="level-right"><span class="badge bg-secondary fs-6"><%= @notes.size %></span></div>
</div>

<%# ── Quick capture: one field, press the button (or Enter) to save ───────── %>
<div class="card p-3 mb-4">
  <%= form_with model: @note, url: notes_path, method: :post do |f| %>
    <div class="d-flex gap-2 align-items-start">
      <%= f.text_area :body, rows: 1, class: "form-control", placeholder: t("notes.quick_placeholder"),
            data: { action: "keydown.enter->nothing" } %>
      <%= f.submit t("notes.add"), class: "btn btn-primary" %>
    </div>
  <% end %>
</div>

<% if @notes.any? %>
  <div class="row g-3">
    <% @notes.each do |note| %>
      <div class="col-md-4">
        <div class="card p-3 h-100 <%= 'border-warning' if note.pinned %>">
          <div class="d-flex justify-content-between align-items-start mb-2">
            <span class="fw-semibold"><%= note.pinned ? "📌 " : "" %><%= note.display_title %></span>
            <div class="d-flex gap-1">
              <%= button_to (note.pinned ? "📌" : "📍"), toggle_pin_note_path(note), method: :patch,
                    class: "btn btn-sm btn-light py-0", title: t("notes.pin") %>
              <%= button_to "🗄️", toggle_archive_note_path(note), method: :patch,
                    class: "btn btn-sm btn-light py-0", title: t("notes.archive") %>
              <%= button_to "✕", note_path(note), method: :delete,
                    class: "btn btn-sm btn-outline-danger py-0",
                    form: { data: { turbo_confirm: t("notes.confirm_delete") } } %>
            </div>
          </div>
          <details>
            <summary class="text-muted fs-7 mb-2" style="cursor:pointer;"><%= t("notes.edit") %></summary>
            <%= form_with model: note, url: note_path(note), method: :patch do |f| %>
              <%= f.text_field :title, value: note.title, class: "form-control form-control-sm mb-2", placeholder: t("notes.title_placeholder") %>
              <%= f.text_area :body, value: note.body, rows: 4, class: "form-control form-control-sm mb-2" %>
              <%= f.submit t("notes.save"), class: "btn btn-sm btn-primary" %>
            <% end %>
          </details>
          <% unless note.body.to_s.strip.empty? %>
            <p class="fs-7 mt-2 mb-0" style="white-space:pre-wrap;"><%= note.body.to_s.truncate(280) %></p>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="card p-4 text-center text-muted"><p class="mb-0"><%= t("notes.empty") %></p></div>
<% end %>

<% if @archived.any? %>
  <details class="mt-4">
    <summary class="fw-semibold" style="cursor:pointer;"><%= t("notes.archived") %> (<%= @archived.size %>)</summary>
    <div class="row g-3 mt-1">
      <% @archived.each do |note| %>
        <div class="col-md-4">
          <div class="card p-3 h-100 bg-light">
            <div class="d-flex justify-content-between align-items-start mb-1">
              <span class="fw-semibold text-muted"><%= note.display_title %></span>
              <div class="d-flex gap-1">
                <%= button_to "↩︎", toggle_archive_note_path(note), method: :patch,
                      class: "btn btn-sm btn-light py-0", title: t("notes.unarchive") %>
                <%= button_to "✕", note_path(note), method: :delete,
                      class: "btn btn-sm btn-outline-danger py-0",
                      form: { data: { turbo_confirm: t("notes.confirm_delete") } } %>
              </div>
            </div>
            <p class="fs-7 mb-0 text-muted" style="white-space:pre-wrap;"><%= note.body.to_s.truncate(200) %></p>
          </div>
        </div>
      <% end %>
    </div>
  </details>
<% end %>
