<% content_for(:title) { "Documentation" } %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="fw-bold mb-0">📄 Project Documentation</h1>
</div>

<%# Type filter tabs %>
<div class="nav nav-tabs mb-4">
  <ul>
    <li class="<%= @type_filter.nil? ? 'is-active' : '' %>">
      <%= link_to "All", customer_portal_documents_path %>
    </li>
    <% { "spec" => "Spec", "architecture" => "Architecture", "runbook" => "Runbook",
         "user_story" => "User Stories", "timeline" => "Timeline", "other" => "Other" }.each do |k, v| %>
      <li class="<%= @type_filter == k ? 'is-active' : '' %>">
        <%= link_to v, customer_portal_documents_path(doc_type: k) %>
      </li>
    <% end %>
  </ul>
</div>

<% if @documents.empty? %>
  <div class="card p-3 mb-3 text-center py-6">
    <p class="text-muted">No documents available yet.</p>
  </div>
<% else %>
  <div class="row">
    <% @documents.each do |doc| %>
      <div class="col-6">
        <div class="card p-3 mb-3 p-4" style="height:100%;">
          <div class="d-flex justify-content-between is-align-items-start mb-2">
            <div style="flex:1;">
              <%= link_to doc.title, customer_portal_document_path(doc), class: "fw-semibold fs-6", target: "_blank", rel: "noopener" %>
            </div>
            <div class="ms-2">
              <span class="badge bg-info text-dark is-light is-small"><%= doc.doc_type.to_s.humanize %></span>
            </div>
          </div>

          <% if doc.summary.present? %>
            <p class="fs-7 text-muted mb-2"><%= truncate(doc.summary, length: 150) %></p>
          <% end %>

          <div class="d-flex justify-content-between align-items-center mt-3" style="border-top:1px solid #f5f5f5; padding-top:8px;">
            <span class="fs-7 text-muted">
              📁 <%= doc.project.name %>
              <% if doc.version_number.present? %> · v<%= doc.version_number %><% end %>
            </span>
            <span class="fs-7 text-muted"><%= doc.updated_at.strftime("%b %-d, %Y") %></span>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
