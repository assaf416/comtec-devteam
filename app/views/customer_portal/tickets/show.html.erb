<% is_story = @ticket.ticket_type_feature_request?
   content_for(:title) { @ticket.title }
%>

<div class="mb-4">
  <%= link_to "← Back to #{is_story ? 'Stories' : 'Tickets'}", customer_portal_tickets_path(type: @ticket.ticket_type), class: "text-primary fs-7" %>
</div>

<div class="row">

  <div class="col-8">
    <div class="card p-3 mb-3">
      <div class="d-flex justify-content-between is-align-items-start mb-3">
        <div>
          <span class="badge bg-light text-dark is-small mb-2"><%= is_story ? "💡 Feature Request" : "🎫 Support Ticket" %></span>
          <h1 class="fw-bold fs-4 mb-0"><%= @ticket.title %></h1>
        </div>
        <div class="d-flex">
          <% color = { "critical" => "is-danger", "high" => "is-warning", "medium" => "is-info", "low" => "is-light" }[@ticket.priority] || "is-light" %>
          <span class="badge bg-secondary <%= color %> me-1"><%= @ticket.priority.to_s.humanize %></span>
          <% scolor = @ticket.status_resolved? || @ticket.status_closed? ? "is-success" :
                      @ticket.status_open? || @ticket.status_in_progress? ? "is-warning" : "is-light" %>
          <span class="badge bg-secondary <%= scolor %>"><%= @ticket.status.to_s.humanize %></span>
        </div>
      </div>

      <% if @ticket.body.present? %>
        <div class="content">
          <%= simple_format @ticket.body %>
        </div>
      <% else %>
        <p class="text-muted is-italic">No description provided.</p>
      <% end %>
    </div>
  </div>

  <div class="col">
    <div class="card p-3 mb-3">
      <p class="text-uppercase text-muted fw-bold small mb-2">Details</p>
      <table class="table table-sm w-100 fs-7">
        <tbody>
          <tr><th>Status</th><td><%= @ticket.status.to_s.humanize %></td></tr>
          <tr><th>Priority</th><td><%= @ticket.priority.to_s.humanize %></td></tr>
          <tr>
            <th>Assigned to</th>
            <td><%= @ticket.assigned_to&.display_name || "—" %></td>
          </tr>
          <tr><th>Submitted</th><td><%= @ticket.created_at.strftime("%b %-d, %Y %H:%M") %></td></tr>
          <tr><th>Updated</th><td><%= @ticket.updated_at.strftime("%b %-d, %Y %H:%M") %></td></tr>
          <% if @ticket.resolved_at.present? %>
            <tr><th>Resolved</th><td><%= @ticket.resolved_at.strftime("%b %-d, %Y") %></td></tr>
          <% end %>
        </tbody>
      </table>

      <% if @ticket.internal_ticket.present? %>
        <div class="alert alert-success py-2 px-3 mt-2 fs-7">
          ✅ This request is linked to an internal work item and is being actively tracked by our team.
        </div>
      <% end %>
    </div>
  </div>

</div>
