<% content_for(:title) { "Dashboard" } %>

<div class="d-flex justify-content-between align-items-center mb-5">
  <div>
    <h1 class="fw-bold mb-1">Welcome, <%= current_customer_user.display_name %></h1>
    <p class="subfw-bold fs-6 text-muted"><%= current_customer.display_name %> · <%= Date.today.strftime("%B %-d, %Y") %></p>
  </div>
  <div class="btn btn-secondarys">
    <%= link_to "＋ #{t('buttons.new_ticket')}",  new_customer_portal_ticket_path(type: "support"),        class: "btn btn-primary" %>
    <%= link_to "＋ #{t('buttons.new_story')}",   new_customer_portal_ticket_path(type: "feature_request"), class: "btn btn-primary is-light" %>
  </div>
</div>

<%# ── Stat cards ──────────────────────────────────────────────────────────── %>
<div class="row mb-5">
  <div class="col">
    <%= link_to customer_portal_tickets_path(type: "support"), class: "card p-3 mb-3 text-center p-4 #{@open_tickets > 0 ? 'bg-warning-subtle' : ''}" do %>
      <p class="text-uppercase text-muted fw-bold small">Open Tickets</p>
      <p class="fw-bold fs-2"><%= @open_tickets %></p>
    <% end %>
  </div>
  <div class="col">
    <%= link_to customer_portal_tickets_path(type: "feature_request"), class: "card p-3 mb-3 text-center p-4 bg-primary-subtle" do %>
      <p class="text-uppercase text-muted fw-bold small">Stories / Feature Requests</p>
      <p class="fw-bold fs-2"><%= @open_stories %></p>
    <% end %>
  </div>
  <div class="col">
    <%= link_to customer_portal_messages_path, class: "card p-3 mb-3 text-center p-4" do %>
      <p class="text-uppercase text-muted fw-bold small">Messages (last 7 days)</p>
      <p class="fw-bold fs-2"><%= @unread_messages %></p>
    <% end %>
  </div>
  <div class="col">
    <%= link_to customer_portal_milestones_path, class: "card p-3 mb-3 text-center p-4 #{@upcoming_milestones.any? ? 'bg-success-subtle' : ''}" do %>
      <p class="text-uppercase text-muted fw-bold small">Upcoming Milestones</p>
      <p class="fw-bold fs-2"><%= @upcoming_milestones.size %></p>
    <% end %>
  </div>
</div>

<div class="row">

  <%# ── Left: Tickets + Stories ────────────────────────────────────────────── %>
  <div class="col-7">

    <div class="card p-3 mb-4">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold fs-5 mb-0">🎫 Recent Support Tickets</h2>
        <%= link_to "View all →", customer_portal_tickets_path(type: "support"), class: "fs-7 text-primary" %>
      </div>
      <% if @recent_tickets.empty? %>
        <p class="text-muted">No support tickets yet.</p>
      <% else %>
        <% @recent_tickets.each do |t| %>
          <div class="d-flex justify-content-between py-2" style="border-bottom:1px solid #f5f5f5;">
            <div>
              <%= link_to t.title, customer_portal_ticket_path(t), class: "fw-medium" %>
            </div>
            <div class="d-flex">
              <span class="badge bg-secondary me-1 <%= t.status_open? || t.status_in_progress? ? 'is-warning' : 'is-success is-light' %>">
                <%= t.status.to_s.humanize %>
              </span>
              <span class="badge bg-secondary is-light"><%= t.priority.to_s.humanize %></span>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>

    <div class="card p-3 mb-4">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold fs-5 mb-0">💡 Recent Stories & Feature Requests</h2>
        <%= link_to "View all →", customer_portal_tickets_path(type: "feature_request"), class: "fs-7 text-primary" %>
      </div>
      <% if @recent_stories.empty? %>
        <p class="text-muted">No feature requests yet. <%= link_to "Submit one →", new_customer_portal_ticket_path(type: "feature_request"), class: "text-primary" %></p>
      <% else %>
        <% @recent_stories.each do |s| %>
          <div class="d-flex justify-content-between py-2" style="border-bottom:1px solid #f5f5f5;">
            <div>
              <%= link_to s.title, customer_portal_ticket_path(s), class: "fw-medium" %>
            </div>
            <span class="badge bg-secondary <%= s.status_resolved? || s.status_closed? ? 'is-success' : 'is-link is-light' %>">
              <%= s.status.to_s.humanize %>
            </span>
          </div>
        <% end %>
      <% end %>
    </div>

  </div>

  <%# ── Right: Messages + Milestones ───────────────────────────────────────── %>
  <div class="col">

    <div class="card p-3 mb-4">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold fs-5 mb-0">💬 Latest Messages</h2>
        <%= link_to "View thread →", customer_portal_messages_path, class: "fs-7 text-primary" %>
      </div>
      <% if @latest_messages.empty? %>
        <p class="text-muted">No messages yet.</p>
      <% else %>
        <% @latest_messages.each do |msg| %>
          <div class="mb-2 p-2 rounded" style="background:#f8f8f8;border-radius:6px;">
            <p class="fs-7 text-muted mb-1">
              <strong><%= msg.sender&.display_name || "Team" %></strong>
              · <%= msg.created_at.strftime("%b %-d, %H:%M") %>
            </p>
            <p class="fs-6 mb-0"><%= truncate(msg.body, length: 100) %></p>
          </div>
        <% end %>
      <% end %>
    </div>

    <div class="card p-3 mb-4">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold fs-5 mb-0">🏁 Upcoming Milestones</h2>
        <%= link_to "View all →", customer_portal_milestones_path, class: "fs-7 text-primary" %>
      </div>
      <% if @upcoming_milestones.empty? %>
        <p class="text-muted">No upcoming milestones.</p>
      <% else %>
        <% @upcoming_milestones.each do |ms| %>
          <div class="d-flex justify-content-between py-2" style="border-bottom:1px solid #f5f5f5;">
            <div>
              <span class="fw-medium"><%= ms.name %></span>
              <span class="badge bg-light text-dark is-small ms-1"><%= ms.project.name %></span>
            </div>
            <div>
              <span class="badge bg-secondary <%= ms.due_date < Date.today ? 'is-danger' : (ms.due_date == Date.today ? 'is-warning' : 'is-success is-light') %>">
                <%= ms.due_date.strftime("%b %-d") %>
              </span>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>

  </div>

</div>
