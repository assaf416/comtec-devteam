<% content_for :title, "Daily Meeting" %>

<div class="level mb-3">
  <div class="level-left">
    <div>
      <h1 class="fw-bold mb-1">🗣️ Daily Meeting</h1>
      <% if @sprint %>
        <p class="text-muted fs-7 mb-0"><%= @project.name %> · <%= @sprint.name %> · <%= @sprint.days_remaining %> days remaining</p>
      <% end %>
    </div>
  </div>
  <div class="level-right">
    <%= render "shared/sprint_picker", sprints: @sprint_options, selected: @sprint, url: daily_meeting_path %>
  </div>
</div>

<% unless @sprint %>
  <div class="alert alert-light">No active sprint. Pick one above, or set a current sprint on a project.</div>
<% else %>

  <%# Team video bar %>
  <%= render "shared/jitsi_bar", room: "devteam-daily-sprint-#{@sprint.id}", title: "Daily Standup — #{@sprint.name}" %>

  <%# Per-developer: yesterday / today %>
  <% if @standups.empty? %>
    <div class="alert alert-light">No tickets assigned to anyone in this sprint yet.</div>
  <% end %>

  <div class="row g-3">
    <% @standups.each do |s| %>
      <div class="col-md-6 col-lg-4">
        <div class="card p-3 h-100">
          <div class="d-flex align-items-center gap-2 mb-2">
            <%= user_avatar(s[:member], size: 36) %>
            <div>
              <div class="fw-bold"><%= s[:member].display_name %></div>
              <div class="text-muted fs-8"><%= s[:today_tickets].size %> open · <%= s[:in_progress].size %> in progress</div>
            </div>
          </div>

          <div class="mb-2">
            <div class="fw-semibold fs-7 text-success mb-1">✅ Yesterday</div>
            <% if s[:done_yesterday].any? %>
              <ul class="mb-0 ps-3 fs-7">
                <% s[:done_yesterday].each do |task| %>
                  <li>
                    <%= task.description.truncate(60) %>
                    <%= link_to "T-#{task.ticket_id}", ticket_path(task.ticket), class: "text-muted text-decoration-none" %>
                  </li>
                <% end %>
              </ul>
            <% else %>
              <p class="text-muted fs-8 mb-0">Nothing completed yesterday.</p>
            <% end %>
          </div>

          <div>
            <div class="fw-semibold fs-7 text-primary mb-1">🎯 Today</div>
            <% if s[:in_progress].any? %>
              <ul class="mb-1 ps-3 fs-7">
                <% s[:in_progress].each do |task| %>
                  <li>
                    <span class="badge bg-info text-dark">in&nbsp;progress</span>
                    <%= task.description.truncate(55) %>
                    <%= link_to "T-#{task.ticket_id}", ticket_path(task.ticket), class: "text-muted text-decoration-none" %>
                  </li>
                <% end %>
              </ul>
            <% end %>
            <% if s[:today_tickets].any? %>
              <ul class="mb-0 ps-3 fs-7">
                <% s[:today_tickets].each do |ticket| %>
                  <li>
                    <%= link_to ticket.title.truncate(55), ticket_path(ticket), class: "text-decoration-none" %>
                    <%= status_tag(ticket.status) %>
                    <span class="d-inline-block"><%= render "tickets/progress_badges", ticket: ticket %></span>
                  </li>
                <% end %>
              </ul>
            <% elsif s[:in_progress].empty? %>
              <p class="text-muted fs-8 mb-0">No open work planned.</p>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
