<% content_for(:page_title) { @sprint.name } %>

<%# ── Header ──────────────────────────────────────────────────────────────── %>
<div class="mobile-card">
  <div class="mobile-card-header">
    <div style="flex:1;overflow:hidden;">
      <div class="mobile-card-meta">
        <%= link_to @project.name, mobile_project_path(@project), class: "has-text-link" %>
      </div>
      <div style="font-weight:800;font-size:1rem;">🏃 <%= @sprint.name %></div>
      <div class="mobile-card-meta">
        <%= @sprint.start_date&.strftime("%b %-d") %> – <%= @sprint.end_date&.strftime("%b %-d, %Y") %>
      </div>
    </div>
    <span class="tag is-rounded is-small <%= @sprint.active? ? 'is-success' : 'is-light' %>"><%= @sprint.status.humanize %></span>
  </div>
  <div class="mobile-card-body">
    <div style="display:flex;justify-content:space-between;font-size:0.7rem;color:#8a93a2;font-weight:700;">
      <span><%= @sprint.progress_percent %>% complete</span>
      <span><%= @sprint.total_actual_hours %>h / <%= @sprint.total_estimated_hours %>h</span>
    </div>
    <progress class="progress is-success" value="<%= @sprint.progress_percent %>" max="100" style="height:7px;margin-top:0.35rem;"></progress>
    <div class="columns is-mobile is-gapless mt-1" style="margin:0;text-align:center;">
      <div class="column">
        <div style="font-size:1.3rem;font-weight:800;color:#2d3748;"><%= @tickets.size %></div>
        <div style="font-size:0.6rem;font-weight:700;text-transform:uppercase;color:#8a93a2;">Tickets</div>
      </div>
      <div class="column">
        <div style="font-size:1.3rem;font-weight:800;color:#3182ce;"><%= @pull_requests.size %></div>
        <div style="font-size:0.6rem;font-weight:700;text-transform:uppercase;color:#8a93a2;">PRs</div>
      </div>
      <div class="column">
        <div style="font-size:1.3rem;font-weight:800;color:#2d3748;"><%= @members.size %></div>
        <div style="font-size:0.6rem;font-weight:700;text-transform:uppercase;color:#8a93a2;">Members</div>
      </div>
    </div>
    <%= link_to "Open full sprint ›", sprint_path(@sprint), class: "button is-light is-small is-rounded is-fullwidth mt-2" %>
  </div>
</div>

<%# ── Members ─────────────────────────────────────────────────────────────── %>
<p class="mobile-section-title">👥 Members</p>
<%= render "mobile/members", members: @members %>

<%# ── Tickets ─────────────────────────────────────────────────────────────── %>
<p class="mobile-section-title">🎫 Tickets</p>
<%= render "mobile/tickets", tickets: @tickets %>

<%# ── Pull Requests ───────────────────────────────────────────────────────── %>
<p class="mobile-section-title">🔀 Pull Requests</p>
<%= render "mobile/prs", prs: @pull_requests %>

<%# ── Notes & Documents ───────────────────────────────────────────────────── %>
<p class="mobile-section-title">📄 Notes &amp; Documents</p>
<%= render "mobile/notes", notes: @notes %>

<%# ── Comments ────────────────────────────────────────────────────────────── %>
<p class="mobile-section-title">💬 Comments</p>
<%= render "mobile/comments", comments: @comments %>
