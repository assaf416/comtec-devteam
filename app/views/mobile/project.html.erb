<% content_for(:page_title) { @project.name } %>

<%# ── Header ──────────────────────────────────────────────────────────────── %>
<div class="mobile-card">
  <div class="mobile-card-header">
    <div style="width:42px;height:42px;border-radius:11px;background:#4a90d9;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:800;font-size:1.1rem;flex-shrink:0;">
      <%= @project.name[0].to_s.upcase %>
    </div>
    <div style="flex:1;overflow:hidden;">
      <div style="font-weight:800;font-size:1rem;">📦 <%= @project.name %></div>
      <div class="mobile-card-meta"><%= @project.tech_stack %></div>
    </div>
    <span class="tag is-rounded is-small <%= @project.active? ? 'is-success is-light' : 'is-light' %>">
      <%= @project.active? ? "Active" : "Inactive" %>
    </span>
  </div>
  <div class="mobile-card-body">
    <div class="columns is-mobile is-gapless" style="margin:0;text-align:center;">
      <div class="column">
        <div style="font-size:1.3rem;font-weight:800;color:#d97706;"><%= @tickets.count %></div>
        <div style="font-size:0.6rem;font-weight:700;text-transform:uppercase;color:#8a93a2;">Tickets</div>
      </div>
      <div class="column">
        <div style="font-size:1.3rem;font-weight:800;color:#3182ce;"><%= @pull_requests.size %></div>
        <div style="font-size:0.6rem;font-weight:700;text-transform:uppercase;color:#8a93a2;">PRs</div>
      </div>
      <div class="column">
        <div style="font-size:1.3rem;font-weight:800;color:#2d3748;"><%= @members.size %></div>
        <div style="font-size:0.6rem;font-weight:700;text-transform:uppercase;color:#8a93a2;">Members</div>
      </div>
    </div>
    <%= link_to "Open full project ›", project_path(@project), class: "button is-light is-small is-rounded is-fullwidth mt-2" %>
  </div>
</div>

<%# ── Sprints ─────────────────────────────────────────────────────────────── %>
<p class="mobile-section-title">🏃 Sprints</p>
<% if @sprints.any? %>
  <div class="box p-0" style="overflow:hidden;">
    <% @sprints.each do |sprint| %>
      <%= link_to mobile_sprint_path(sprint), class: "ticket-item px-3" do %>
        <span class="ticket-dot <%= sprint.active? ? 'dot-low' : 'dot-default' %>"></span>
        <div style="flex:1;overflow:hidden;">
          <div class="ticket-title"><%= sprint.name.truncate(38) %></div>
          <div class="mobile-card-meta"><%= sprint.progress_percent %>% done · <%= sprint.tickets.size %> tickets</div>
        </div>
        <span class="tag is-rounded is-small <%= sprint.active? ? 'is-success is-light' : 'is-light' %>"><%= sprint.status.humanize %></span>
      <% end %>
    <% end %>
  </div>
<% else %>
  <p style="color:#a0aec0;font-size:0.82rem;">No sprints.</p>
<% end %>

<%# ── Members ─────────────────────────────────────────────────────────────── %>
<p class="mobile-section-title">👥 Members</p>
<%= render "mobile/members", members: @members %>

<%# ── Tickets ─────────────────────────────────────────────────────────────── %>
<p class="mobile-section-title">🎫 Tickets</p>
<%= render "mobile/tickets", tickets: @tickets %>

<%# ── Pull Requests ───────────────────────────────────────────────────────── %>
<p class="mobile-section-title">🔀 Pull Requests</p>
<%= render "mobile/prs", prs: @pull_requests %>

<%# ── Notes & Documents ───────────────────────────────────────────────────── %>
<p class="mobile-section-title">📄 Notes &amp; Documents</p>
<%= render "mobile/notes", notes: @notes %>

<%# ── Comments ────────────────────────────────────────────────────────────── %>
<p class="mobile-section-title">💬 Recent Comments</p>
<%= render "mobile/comments", comments: @comments %>
