<% content_for(:page_title) { t('mobile.nav.projects') } %>

<% @projects.each do |project| %>
  <%
    open_tickets  = project.tickets.where.not(status: [:done, :closed]).count
    open_prs      = project.pull_requests.where(status: :open).count rescue 0
  %>
  <div class="mobile-card">
    <div class="mobile-card-header">
      <div style="width:40px;height:40px;border-radius:10px;background:#4a90d9;
           display:flex;align-items:center;justify-content:center;
           color:#fff;font-weight:800;font-size:1rem;flex-shrink:0;">
        <%= project.name[0].upcase %>
      </div>
      <div style="flex:1;overflow:hidden;">
        <div style="font-weight:700;font-size:0.95rem;">
          <%= link_to project.name, mobile_project_path(project), class: "has-text-dark" %>
        </div>
        <div class="mobile-card-meta">
          <%= t('mobile.projects.open') %>: <%= open_tickets %>
        </div>
      </div>
      <span class="tag is-rounded is-small <%= project.active? ? 'is-success is-light' : 'is-light' %>">
          <%= project.active? ? t('mobile.projects.active') : t('mobile.projects.inactive') %>
        </span>
    </div>
    <div class="mobile-card-body">
      <div class="columns is-mobile is-gapless" style="margin:0;">
        <div class="column has-text-centered">
          <%= link_to project_tickets_path(project), class: "is-block" do %>
            <p style="font-size:1.2rem;font-weight:800;color:<%= open_tickets > 0 ? '#d97706' : '#2d3748' %>"><%= open_tickets %></p>
            <p style="font-size:0.62rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:#8a93a2;"><%= t('mobile.projects.open') %></p>
          <% end %>
        </div>
        <div class="column has-text-centered">
          <%= link_to project_pull_requests_path(project), class: "is-block" do %>
            <p style="font-size:1.2rem;font-weight:800;color:<%= open_prs > 0 ? '#3182ce' : '#2d3748' %>"><%= open_prs %></p>
            <p style="font-size:0.62rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:#8a93a2;"><%= t('mobile.projects.prs') %></p>
          <% end %>
        </div>
        <div class="column has-text-centered">
          <p style="font-size:1.2rem;font-weight:800;color:#2d3748;"><%= project.tickets.where(status: [:done, :closed]).count %></p>
          <p style="font-size:0.62rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:#8a93a2;"><%= t('mobile.projects.done') %></p>
        </div>
      </div>
      <div class="is-flex" style="gap:0.5rem;flex-wrap:wrap;margin-top:0.5rem;">
        <%= link_to mobile_project_path(project), class: "button is-small is-light is-rounded" do %>
          <%= t('mobile.projects.view') %>
        <% end %>
        <%= link_to project_tickets_path(project), class: "button is-small is-light is-rounded" do %>
          <%= t('mobile.projects.tickets_btn') %>
        <% end %>
        <%= link_to project_meetings_path(project), class: "button is-small is-light is-rounded" do %>
          <%= t('mobile.projects.meetings_btn') %>
        <% end %>
      </div>
    </div>
  </div>
<% end %>

<% if @projects.empty? %>
  <div class="has-text-centered py-6" style="color:#bbb;">
    <p style="font-size:3rem;">🗂️</p>
    <p style="color:#8a93a2;"><%= t('mobile.projects.no_projects') %></p>
  </div>
<% end %>
