<%# locals: members (Array/Relation of User) %>
<% if members.present? && members.any? %>
  <div class="mobile-card">
    <div class="mobile-card-body" style="display:flex;flex-wrap:wrap;gap:0.5rem;">
      <% members.each do |u| %>
        <% next unless u %>
        <span style="display:inline-flex;align-items:center;gap:0.4rem;background:#f1f5fb;border-radius:999px;padding:0.2rem 0.7rem 0.2rem 0.2rem;font-size:0.8rem;font-weight:600;">
          <span style="width:26px;height:26px;border-radius:50%;background:#4a90d9;color:#fff;display:inline-flex;align-items:center;justify-content:center;font-size:0.7rem;font-weight:800;">
            <%= u.display_name.to_s.split.map { |w| w[0] }.first(2).join.upcase.presence || "?" %>
          </span>
          <%= u.display_name %>
        </span>
      <% end %>
    </div>
  </div>
<% else %>
  <p style="color:#a0aec0;font-size:0.82rem;padding:0.25rem 0 0.5rem;">No members.</p>
<% end %>
